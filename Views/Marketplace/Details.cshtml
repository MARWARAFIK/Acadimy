@model Acadimy.Models.Marketplace.ProjectPost

@{
    Layout = "~/Views/Shared/LayoutStudent.cshtml";
    ViewData["Title"] = "Project Details";

    var avg = Model.Ratings.Any()
        ? Model.Ratings.Average(r => r.Value)
        : 0;

    var image = string.IsNullOrEmpty(Model.ImagePath)
        ? "/images/default-cover.jpg"
        : Model.ImagePath;

    var authorImage = Model.User != null && !string.IsNullOrEmpty(Model.User.ProfileImagePath)
        ? Model.User.ProfileImagePath
        : "/images/default-user.png";
}

<div class="container py-4">

    <!-- HEADER -->
    <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
        <img src="@image" class="w-100" style="max-height:350px; object-fit:cover;" />

        <div class="card-body p-4">

            <h2 class="fw-bold mb-2">@Model.Title</h2>

            <div class="d-flex align-items-center gap-2 text-muted mb-3">
                <img src="@authorImage"
                     style="width:32px;height:32px;border-radius:50%;" />

                <span>@Model.User?.FullName</span>
                <span>•</span>
                <span>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
            </div>

            <div class="d-flex align-items-center gap-3 mb-3">
                <span class="badge bg-warning text-dark">
                    ⭐ @avg.ToString("0.0")
                </span>

                <span class="text-muted small">
                    @Model.Ratings.Count votes
                </span>
            </div>

            <p class="text-muted">@Model.Description</p>

            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <a href="@Model.FilePath"
                   target="_blank"
                   class="btn btn-outline-success rounded-pill">
                    <i class="bi bi-download"></i> Télécharger le projet
                </a>
            }
        </div>
    </div>

    <!-- ⭐ RATING -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3">⭐ Évaluer ce projet</h5>

            <form asp-action="Rate" method="post" class="d-flex gap-2">
                @Html.AntiForgeryToken()

                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                @for (int i = 1; i <= 5; i++)
                {
                    <button type="submit"
                            name="value"
                            value="@i"
                            class="btn btn-outline-warning">
                        ★
                    </button>
                }
            </form>
        </div>
    </div>

    <!-- 💬 COMMENTS -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">

            <h5 class="fw-bold mb-3">
                💬 Commentaires (@Model.Comments.Count)
            </h5>

            <!-- ADD COMMENT -->
            <form asp-action="AddComment" method="post" class="mb-4">
                @Html.AntiForgeryToken()

                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                <div class="d-flex gap-2">
                    <input type="text"
                           name="content"
                           class="form-control"
                           placeholder="Write a comment..." />

                    <button class="btn btn-success">
                        Send
                    </button>
                </div>
            </form>

            <!-- LIST COMMENTS -->
            @if (Model.Comments.Any())
            {
                foreach (var c in Model.Comments.OrderByDescending(x => x.CreatedAt))
                {
                    var cImg = string.IsNullOrEmpty(c.User?.ProfileImagePath)
                        ? "/images/default-user.png"
                        : c.User.ProfileImagePath;

                    <div class="d-flex gap-3 mb-3">

                        <img src="@cImg"
                             style="width:35px;height:35px;border-radius:50%;" />

                        <div class="flex-grow-1">
                            <div style="background:#f1f1f1; padding:10px; border-radius:10px;">
                                <b>@c.User?.FullName</b><br />
                                @c.Content
                            </div>

                            <small class="text-muted">
                                @c.CreatedAt.ToString("dd MMM yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No comments yet.</p>
            }

        </div>
    </div>

</div>