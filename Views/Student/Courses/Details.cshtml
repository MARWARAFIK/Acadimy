@using Acadimy.Models.Teacher
@model Acadimy.Models.Teacher.TeacherCourse

@{
    Layout = "~/Views/Shared/LayoutStudent.cshtml";
    ViewData["Title"] = "Détails du cours";

    bool isJoined = ViewBag.IsJoined != null && (bool)ViewBag.IsJoined;
    int progress = ViewBag.Progress != null ? (int)ViewBag.Progress : 0;
    string status = ViewBag.Status?.ToString() ?? "Not joined";
    var completedLessonIds = ViewBag.CompletedLessonIds as List<int> ?? new List<int>();
}

<div class="course-details-page">
    <a asp-controller="StudentCourses" asp-action="Index" class="btn btn-light rounded-pill mb-3">
        <i class="bi bi-arrow-left"></i> Retour
    </a>

    <div class="course-details-card">
        <div class="details-cover">
            @if (!string.IsNullOrEmpty(Model.ThumbnailPath))
            {
                <img src="@Model.ThumbnailPath" />
            }
            else
            {
                <div class="course-empty-img">
                    <i class="bi bi-journal-bookmark"></i>
                </div>
            }
        </div>

        <div class="details-body">
            <span class="course-badge">@Model.Category</span>

            <h1>@Model.Title</h1>

            <div class="details-meta">
                <span><i class="bi bi-bar-chart"></i> @Model.Level</span>
                <span><i class="bi bi-calendar"></i> @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                <span><i class="bi bi-graph-up"></i> @progress%</span>
                <span><i class="bi bi-info-circle"></i> @status</span>
            </div>

            @if (isJoined)
            {
                <div class="big-progress-box mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>Votre progression</strong>
                        <strong>@progress%</strong>
                    </div>

                    <div class="progress">
                        <div class="progress-bar" style="width:@progress%"></div>
                    </div>
                </div>
            }

            <p class="details-desc">
                @(string.IsNullOrWhiteSpace(Model.Description)
                    ? "Aucune description disponible."
                    : Model.Description)
            </p>

            <div class="teacher-box">
                <img src="@(string.IsNullOrEmpty(Model.User?.ProfileImagePath) ? "/images/default-user.png" : Model.User.ProfileImagePath)" />

                <div>
                    <h5>@Model.User?.FullName</h5>
                    <p>@Model.User?.Grade - @Model.User?.Specialite</p>
                </div>

                <a asp-controller="TeacherProfile"
                   asp-action="ViewProfile"
                   asp-route-id="@Model.UserId"
                   class="btn btn-outline-success rounded-pill ms-auto">
                    Voir profile
                </a>
            </div>

            <div class="details-buttons">
                @if (!isJoined)
                {
                    <form asp-controller="StudentCourses"
                          asp-action="Join"
                          asp-route-id="@Model.Id"
                          method="post">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn-join">
                            <i class="bi bi-check-circle"></i> S'inscrire
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn-joined" disabled>
                        <i class="bi bi-check2-circle"></i> Déjà inscrit
                    </button>

                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        <a href="@Model.FilePath" class="btn-download" download>
                            <i class="bi bi-download"></i> Télécharger
                        </a>
                    }
                }
            </div>

            <hr class="my-4" />

            <h4 class="fw-bold mb-3">
                <i class="bi bi-list-check text-success"></i> Lessons
            </h4>

            @if (Model.Lessons != null && Model.Lessons.Any())
            {
                <div class="list-group">
                    @foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
                    {
                        bool done = completedLessonIds.Contains(lesson.Id);

                        <div class="list-group-item d-flex justify-content-between align-items-center rounded-3 mb-2">
                            <div>
                                <strong>@lesson.Order. @lesson.Title</strong>
                                <div class="text-muted small">@lesson.Description</div>
                            </div>

                            @if (isJoined)
                            {
                                if (done)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">
                                        <i class="bi bi-check2-circle"></i> Terminé
                                    </span>
                                }
                                else
                                {
                                    <form asp-controller="StudentCourses"
                                          asp-action="CompleteLesson"
                                          method="post"
                                          class="m-0">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="lessonId" value="@lesson.Id" />

                                        <button class="btn btn-success btn-sm rounded-pill">
                                            Terminer
                                        </button>
                                    </form>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">Inscrivez-vous pour commencer</span>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted text-center py-4">
                    Aucune lesson disponible.
                </div>
            }
        </div>
    </div>
</div>