@model List<Acadimy.Models.Student.StudentPost>

@{
    Layout = "~/Views/Shared/LayoutStudent.cshtml";
    ViewData["Title"] = "Archive";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Archive</h2>
            <p class="text-muted">Vos posts archivés</p>
        </div>

        <a asp-controller="Profile" asp-action="Index" class="btn btn-light">
            <i class="bi bi-arrow-left"></i> Retour au profil
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var post in Model)
        {
            <div class="card mb-3 shadow-sm border-0 rounded-4">
                <div class="card-body">

                    @if (!string.IsNullOrWhiteSpace(post.Content))
                    {
                        <p>@post.Content</p>
                    }

                    @if (!string.IsNullOrEmpty(post.ImagePath))
                    {
                        <img src="@post.ImagePath" class="img-fluid rounded-3 mb-3" />
                    }

                    <small class="text-muted">
                        @post.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </small>

                    <div class="d-flex gap-2 mt-3">
                        <form asp-controller="Posts" asp-action="Restore" method="post" class="w-50">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@post.Id" />

                            <button type="submit" class="btn btn-outline-success w-100">
                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                            </button>
                        </form>

                        <form asp-controller="Posts" asp-action="Delete" method="post" class="w-50">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@post.Id" />

                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-light border">
            Aucun post archivé.
        </div>
    }

</div>