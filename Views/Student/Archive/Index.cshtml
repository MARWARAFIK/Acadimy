@model List<Acadimy.Models.Student.StudentPost>

@{
    Layout = "~/Views/Shared/LayoutStudent.cshtml";
    ViewData["Title"] = "Archive";
}

<section class="teacher-white-page">
    <div class="teacher-white-container">

        <!-- HEADER -->
        <div class="teacher-page-header">
            <div>
                <span class="page-badge">ARCHIVE</span>
                <h1>Posts archivés</h1>
                <p>Vos publications archivées</p>
            </div>

            <a asp-controller="Profile" asp-action="Index" class="btn-acadimy-outline">
                <i class="bi bi-arrow-left"></i> Retour au profil
            </a>
        </div>

        <!-- CONTENT -->
        @if (Model != null && Model.Any())
        {
            foreach (var post in Model)
            {
                <div class="teacher-card">

                    @if (!string.IsNullOrWhiteSpace(post.Content))
                    {
                        <p class="mb-2">@post.Content</p>
                    }

                    @if (!string.IsNullOrEmpty(post.ImagePath))
                    {
                        <img src="@post.ImagePath" class="archive-img" />
                    }

                    <div class="archive-meta">
                        <i class="bi bi-calendar"></i>
                        @post.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>

                    <div class="archive-actions">

                        <!-- RESTORE -->
                        <form asp-controller="Posts" asp-action="Restore" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@post.Id" />

                            <button type="submit" class="btn-acadimy-main">
                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                            </button>
                        </form>

                        <!-- DELETE -->
                        <form asp-controller="Posts" asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="postId" value="@post.Id" />

                            <button type="submit" class="btn-acadimy-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="teacher-empty">
                <i class="bi bi-archive"></i>
                <h3>Aucun post archivé</h3>
                <p>Vos posts archivés apparaîtront ici.</p>
            </div>
        }

    </div>
</section>