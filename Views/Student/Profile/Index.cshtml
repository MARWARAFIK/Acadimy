@model Acadimy.ViewModels.Student.ProfileViewModel

@{
    Layout = "~/Views/Shared/LayoutStudent.cshtml";

    var cover = string.IsNullOrEmpty(Model.CoverImagePath)
        ? "/images/default-cover.jpg"
        : Model.CoverImagePath;

    var profile = string.IsNullOrEmpty(Model.ProfileImagePath)
        ? "/images/default-user.png"
        : Model.ProfileImagePath;
}

<div class="student-profile-page">

    <!-- COVER -->
    <div class="profile-cover-box">
        <img src="@cover" class="profile-cover-img" />
    </div>

    <!-- HEADER -->
    <div class="profile-head-box">
        <div class="profile-avatar-wrap">
            <img src="@profile" class="profile-avatar-img" />
        </div>

        <div class="profile-basic-info">
            <h2>@Model.FullName</h2>
            <p class="profile-subtitle">@Model.Filiere - @Model.Niveau</p>
            <p class="profile-location">@Model.Location</p>
        </div>

        <div class="profile-action">
            <a asp-controller="Settings" asp-action="Index" class="btn btn-success">
                Edit Profile
            </a>
        </div>
    </div>

    <div class="profile-content-section">
        <div class="row">

            <!-- LEFT -->
            <div class="col-lg-8">

                <!-- ABOUT -->
                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <h3>About</h3>
                        <p>@Model.Bio</p>
                    </div>
                </div>

                <!-- CREATE POST -->
                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <h3>Create Post</h3>

                        <form asp-controller="Posts" asp-action="Create" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()

                            <textarea name="Content"
                                      class="form-control mb-3"
                                      placeholder="Write something..."
                                      rows="4"></textarea>

                            <input type="file" name="Image" class="form-control mb-3" />

                            <button class="btn btn-success w-100">Publish</button>
                        </form>
                    </div>
                </div>

                <!-- POSTS -->
                @if (Model.Posts != null && Model.Posts.Any())
                {
                    <div class="card profile-card-box mb-4">
                        <div class="card-body p-3">
                            <h3 class="profile-section-title mb-3">My Posts</h3>

                            @foreach (var post in Model.Posts)
                            {
                                <div class="fb-post-card mb-3">
                                    <div class="fb-post-header">
                                        <div class="fb-post-user">
                                            <img src="@(string.IsNullOrEmpty(post.ProfileImagePath) ? "/images/default-user.png" : post.ProfileImagePath)"
                                                 class="fb-post-avatar"
                                                 alt="Profile" />

                                            <div>
                                                <div class="fb-post-name">@post.FullName</div>
                                                <div class="fb-post-date">@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="fb-post-body">
                                        <p class="fb-post-text">@post.Content</p>

                                        @if (!string.IsNullOrEmpty(post.ImagePath))
                                        {
                                            <img src="@post.ImagePath" class="fb-post-image" alt="Post image" />
                                        }
                                    </div>

                                    <div class="fb-post-stats">
                                        <span>@post.LikesCount Likes</span>
                                        <span>@post.Comments.Count Comments</span>
                                    </div>

                                    <div class="fb-post-actions">
                                        <form asp-controller="Posts" asp-action="Like" method="post" class="m-0 flex-fill">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="postId" value="@post.Id" />
                                            <input type="hidden" name="returnTo" value="Profile" />
                                            <button type="submit" class="fb-action-btn w-100">
                                                @(post.IsLikedByCurrentUser ? "💙 Liked" : "👍 Like")
                                            </button>
                                        </form>

                                        <button type="button" class="fb-action-btn flex-fill" onclick="toggleCommentBox('comment-@post.Id')">
                                            💬 Comment
                                        </button>
                                    </div>

                                    <div class="fb-comment-box" id="comment-@post.Id" style="display:none;">
                                        <form asp-controller="Posts" asp-action="AddComment" method="post" class="mb-3">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="PostId" value="@post.Id" />
                                            <input type="hidden" name="returnTo" value="Profile" />
                                            <input type="text" name="Content" class="form-control fb-comment-input" placeholder="Write a comment..." />
                                        </form>

                                        @if (post.Comments != null && post.Comments.Any())
                                        {
                                            @foreach (var comment in post.Comments)
                                            {
                                                <div class="fb-single-comment">
                                                    <div class="d-flex align-items-start gap-2">
                                                        <img src="@(string.IsNullOrEmpty(comment.ProfileImagePath) ? "/images/default-user.png" : comment.ProfileImagePath)"
                                                             class="fb-comment-avatar"
                                                             alt="Comment user" />

                                                        <div class="fb-comment-content">
                                                            <div class="fb-comment-name">@comment.FullName</div>
                                                            <div class="fb-comment-text">@comment.Content</div>
                                                            <div class="fb-comment-date">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card profile-card-box mb-4">
                        <div class="card-body p-3">
                            <h3 class="profile-section-title mb-3">My Posts</h3>
                            <p class="text-muted mb-0">No posts yet</p>
                        </div>
                    </div>
                }

            <!-- RIGHT -->
            <div class="col-lg-4">

                <div class="card profile-card-box">
                    <div class="card-body p-4">
                        <h3>Info</h3>

                        <p><b>Email:</b> @Model.Email</p>
                        <p><b>Phone:</b> @Model.Phone</p>
                        <p><b>Filiere:</b> @Model.Filiere</p>
                        <p><b>Niveau:</b> @Model.Niveau</p>
                        <p><b>Location:</b> @Model.Location</p>
                        <p><b>Website:</b> @Model.Website</p>
                    </div>
                </div>

            </div>

        </div>
    </div>

</div>
    <script>
            function toggleCommentBox(id) {
                var box = document.getElementById(id);
                if (box.style.display === "none") {
                    box.style.display = "block";
                } else {
                    box.style.display = "none";
                }
            }
    </script>