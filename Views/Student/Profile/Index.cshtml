@model Acadimy.ViewModels.Student.ProfileViewModel

@{
    Layout = "~/Views/Shared/LayoutStudent.cshtml";

    var cover = string.IsNullOrEmpty(Model.CoverImagePath)
        ? "/images/default-cover.jpg"
        : Model.CoverImagePath;

    var profile = string.IsNullOrEmpty(Model.ProfileImagePath)
        ? "/images/default-user.png"
        : Model.ProfileImagePath;
}

<div class="student-profile-page">

    <div class="profile-cover-box">
        <img src="@cover" class="profile-cover-img" />
    </div>

    <div class="profile-head-box">
        <div class="profile-avatar-wrap">
            <img src="@profile" class="profile-avatar-img" />
        </div>

        <div class="profile-basic-info">
            <h2>@Model.FullName</h2>
            <p class="profile-subtitle">@Model.Filiere - @Model.Niveau</p>
            <p class="profile-location"><i class="bi bi-geo-alt"></i> @Model.Location</p>
        </div>

        <div class="profile-action">
            <a asp-controller="Settings" asp-action="Index" class="btn btn-success">
                <i class="bi bi-pencil"></i> Edit Profile
            </a>
        </div>
    </div>

    <div class="profile-content-section">
        <div class="row">

            <div class="col-lg-8">
                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <h3 class="profile-section-title">About</h3>
                        <p class="mb-0">@Model.Bio</p>
                    </div>
                </div>

                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <h3 class="profile-section-title">Create Post</h3>
                        <form asp-controller="Posts" asp-action="Create" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <textarea name="Content" class="form-control mb-3" placeholder="What's on your mind?" rows="3"></textarea>
                            <input type="file" name="Image" class="form-control mb-3" />
                            <button class="btn btn-success w-100">Publish</button>
                        </form>
                    </div>
                </div>

                @if (Model.Posts != null && Model.Posts.Any())
                {
                    @foreach (var post in Model.Posts)
                    {
                        <div class="fb-post-card mb-3">
                            <div class="fb-post-header">
                                <div class="fb-post-user">
                                    <img src="@(string.IsNullOrEmpty(post.ProfileImagePath) ? "/images/default-user.png" : post.ProfileImagePath)" class="fb-post-avatar" />
                                    <div>
                                        <div class="fb-post-name">@post.FullName</div>
                                        <div class="fb-post-date">@post.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="fb-post-body">
                                <p>@post.Content</p>
                                @if (!string.IsNullOrEmpty(post.ImagePath))
                                {
                                    <img src="@post.ImagePath" class="fb-post-image" />
                                }
                            </div>
                            <div class="fb-post-actions">
                                <form asp-controller="Posts" asp-action="Like" method="post" class="m-0 flex-fill">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input type="hidden" name="returnTo" value="Profile" />
                                    <button type="submit" class="fb-action-btn w-100">
                                        @(post.IsLikedByCurrentUser ? "💙 Liked" : "👍 Like") (@post.LikesCount)
                                    </button>
                                </form>
                                <button type="button" class="fb-action-btn flex-fill" onclick="toggleCommentBox('comment-@post.Id')">
                                    💬 Comment (@post.Comments.Count)
                                </button>
                            </div>
                            <div class="fb-comment-box p-3" id="comment-@post.Id" style="display:none; background: #f8f9fa;">
                                <form asp-controller="Posts" asp-action="AddComment" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="PostId" value="@post.Id" />
                                    <input type="hidden" name="returnTo" value="Profile" />
                                    <input type="text" name="Content" class="form-control" placeholder="Write a comment..." />
                                </form>
                                @foreach (var comment in post.Comments)
                                {
                                    <div class="d-flex gap-2 mb-2">
                                        <img src="@(string.IsNullOrEmpty(comment.ProfileImagePath) ? "/images/default-user.png" : comment.ProfileImagePath)" style="width:30px; height:30px; border-radius:50%;" />
                                        <div style="background:#eee; padding:5px 10px; border-radius:10px; font-size:0.9em;">
                                            <b>@comment.FullName</b><br /> @comment.Content
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="col-lg-4">
                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <h3 class="profile-section-title">Contact Information</h3>
                        <ul class="list-unstyled">
                            <li class="mb-2"><strong>Email:</strong> @Model.Email</li>
                            <li class="mb-2"><strong>Phone:</strong> @Model.Phone</li>
                            <li class="mb-2"><strong>Website:</strong> <a href="@Model.Website" target="_blank">@Model.Website</a></li>
                            <li class="mb-2"><strong>Level:</strong> @Model.Niveau</li>
                        </ul>
                    </div>
                </div>

                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <h3 class="profile-section-title">Top Skill</h3>
                        @if (!string.IsNullOrEmpty(Model.Skill))
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-bold">@Model.Skill</span>
                                    <span class="text-success">@Model.SkillPercent%</span>
                                </div>
                                <div class="progress" style="height: 12px; border-radius: 10px;">
                                    <div class="progress-bar bg-success"
                                         role="progressbar"
                                         style="width: @Model.SkillPercent%"
                                         aria-valuenow="@Model.SkillPercent"
                                         aria-valuemin="0"
                                         aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small italic">No skills added in settings.</p>
                        }
                        <a asp-controller="Settings" asp-action="Index" class="btn btn-sm btn-outline-secondary w-100 mt-2">Manage Skills</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleCommentBox(id) {
            var box = document.getElementById(id);
            box.style.display = (box.style.display === "none") ? "block" : "none";
        }
    </script>
}