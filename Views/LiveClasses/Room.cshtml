@model Acadimy.Models.Live.LiveClass

@{
    Layout = User.IsInRole("Enseignant")
        ? "~/Views/Shared/LayoutTeacher.cshtml"
        : "~/Views/Shared/LayoutStudent.cshtml";

    var isOwner = ViewBag.IsOwner != null && (bool)ViewBag.IsOwner;
    var classId = Model.Id;
}

<section class="live-page">
    <div class="live-wrapper">

        <div class="live-room-card">
            <h2>@Model.Title</h2>

            <div class="live-video-grid">
                <video id="localVideo" autoplay muted playsinline></video>
                <video id="remoteVideo" autoplay playsinline></video>
            </div>

            <div class="live-actions">
                <button type="button" id="startBtn" class="live-main-btn">
                    <i class="bi bi-camera-video"></i> Start Camera
                </button>

                <button type="button" id="stopBtn" class="live-outline-btn">
                    <i class="bi bi-camera-video-off"></i> Stop
                </button>

                @if (isOwner)
                {
                    <form asp-action="End" asp-route-id="@Model.Id" method="post" id="endLiveForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="live-danger-btn">
                            <i class="bi bi-x-circle"></i> End Live
                        </button>
                    </form>
                }
            </div>

            <p id="liveStatus" class="live-status">Ready</p>
        </div>

    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const classId = "@classId";
        const statusBox = document.getElementById("liveStatus");

        const localVideo = document.getElementById("localVideo");
        const remoteVideo = document.getElementById("remoteVideo");

        let localStream = null;
        let peerConnection = null;
        let connection = null;

        async function initSignalR() {
        connection = new signalR.HubConnectionBuilder()
        .withUrl("/liveClassHub")
        .withAutomaticReconnect()
        .build();

        connection.on("ReceiveSignal", async function (data) {
        await handleSignal(data);
        });

        await connection.start();
        await connection.invoke("JoinClass", classId);

        statusBox.innerText = "Connected to live";
        }

        function createPeerConnection() {
        const pc = new RTCPeerConnection();

        pc.ontrack = function (event) {
        remoteVideo.srcObject = event.streams[0];
        };

        pc.onicecandidate = function (event) {
        if (event.candidate && connection) {
        connection.invoke("SendSignal", classId, {
        candidate: event.candidate
        });
        }
        };

        return pc;
        }

        async function startCamera() {
        try {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
        alert("Camera not supported. Use HTTPS or localhost.");
        return;
        }

        localStream = await navigator.mediaDevices.getUserMedia({
        video: true,
        audio: true
        });

        localVideo.srcObject = localStream;

        peerConnection = createPeerConnection();

        localStream.getTracks().forEach(function (track) {
        peerConnection.addTrack(track, localStream);
        });

        const offer = await peerConnection.createOffer();
        await peerConnection.setLocalDescription(offer);

        if (connection && connection.state === signalR.HubConnectionState.Connected) {
        await connection.invoke("SendSignal", classId, {
        offer: offer
        });
        }

        statusBox.innerText = "Camera ON";
        }
        catch (err) {
        console.error(err);
        statusBox.innerText = "Camera error: " + err.message;
        alert("Camera error: " + err.message);
        }
        }

        function stopCamera() {
        if (localStream) {
        localStream.getTracks().forEach(function (track) {
        track.stop();
        });
        localStream = null;
        }

        localVideo.srcObject = null;
        remoteVideo.srcObject = null;

        if (peerConnection) {
        peerConnection.close();
        peerConnection = null;
        }

        statusBox.innerText = "Camera OFF";
        }

        async function handleSignal(data) {
        if (data.offer) {
        localStream = await navigator.mediaDevices.getUserMedia({
        video: true,
        audio: true
        });

        localVideo.srcObject = localStream;

        peerConnection = createPeerConnection();

        localStream.getTracks().forEach(function (track) {
        peerConnection.addTrack(track, localStream);
        });

        await peerConnection.setRemoteDescription(new RTCSessionDescription(data.offer));

        const answer = await peerConnection.createAnswer();
        await peerConnection.setLocalDescription(answer);

        await connection.invoke("SendSignal", classId, {
        answer: answer
        });
        }

        if (data.answer && peerConnection) {
        await peerConnection.setRemoteDescription(new RTCSessionDescription(data.answer));
        }

        if (data.candidate && peerConnection) {
        await peerConnection.addIceCandidate(new RTCIceCandidate(data.candidate));
        }
        }

        document.addEventListener("DOMContentLoaded", async function () {
        try {
        await initSignalR();
        } catch (err) {
        console.error(err);
        statusBox.innerText = "SignalR disconnected";
        }

        document.getElementById("startBtn").addEventListener("click", startCamera);
        document.getElementById("stopBtn").addEventListener("click", stopCamera);

        const endForm = document.getElementById("endLiveForm");
        if (endForm) {
        endForm.addEventListener("submit", function () {
        stopCamera();
        });
        }
        });
    </script>
}