@model Acadimy.ViewModels.Teacher.TeacherProfileViewModel
@{
    Layout = "LayoutTeacher";
    ViewData["Title"] = "Mon Profil Enseignant";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm text-center p-4 mb-4" style="border-radius: 15px;">
                <div class="position-relative d-inline-block mx-auto mb-3">
                    <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/images/default-profile.png" : Model.ProfileImagePath)"
                         class="rounded-circle img-thumbnail shadow-sm"
                         style="width: 150px; height: 150px; object-fit: cover;" alt="Profile">
                </div>
                <h4 class="fw-bold">@Model.FullName</h4>
                <div class="badge bg-success-subtle text-success px-3 py-2 rounded-pill mb-3">
                    <i class="bi bi-patch-check"></i> @Model.Grade
                </div>
                <p class="text-muted small"><i class="bi bi-envelope"></i> @Model.Email</p>

                <hr class="my-4">

                <div class="text-start px-2">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Spécialité</span>
                        <span class="fw-semibold small">@Model.Specialite</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Expérience</span>
                        <span class="fw-semibold small">@Model.Experience ans</span>
                    </div>
                </div>

                <a asp-controller="TeacherSettings" asp-action="Index" class="btn btn-outline-success btn-sm mt-4 w-100 rounded-pill fw-bold">
                    <i class="bi bi-pencil-square"></i> Modifier mon profil
                </a>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 15px;">
                <h5 class="fw-bold mb-3"><i class="bi bi-file-person text-success me-2"></i>Biographie académique</h5>
                <p class="text-secondary" style="line-height: 1.8; text-align: justify;">
                    @Model.Bio
                </p>
            </div>

            <div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-award text-success me-2"></i>Domaines d'expertise</h5>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.SkillsList != null && Model.SkillsList.Any())
                    {
                        foreach (var skill in Model.SkillsList)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-medium">
                                @skill
                            </span>
                        }
                    }
                    else
                    {
                        <div class="text-center w-100 py-3">
                            <i class="bi bi-info-circle text-muted mb-2 d-block fs-3"></i>
                            <span class="text-muted small">Aucune compétence renseignée pour le moment.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>