@using Acadimy.ViewModels.Teacher
@model List<TeacherCourseViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Gestion des cours";
}

<section class="teacher-page">
    <div class="teacher-page-container">

        <!-- HEADER -->
        <div class="teacher-page-header">
            <div>
                <span class="page-badge">COURSE MANAGEMENT</span>
                <h1>Gestion de mes cours</h1>
                <p>Consultez et gérez vos publications éducatives</p>
            </div>

            <a asp-action="Create" class="teacher-btn-main">
                <i class="bi bi-plus-lg me-2"></i> Ajouter un cours
            </a>
        </div>

        <!-- TABLE CARD -->
        <div class="teacher-card">

            <div class="table-responsive">
                <table class="table teacher-table align-middle">

                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Titre</th>
                            <th>Catégorie</th>
                            <th>Niveau</th>
                            <th class="text-center">Fichier</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- IMAGE -->
                                    <td>
                                        <div class="table-img">
                                            @if (!string.IsNullOrEmpty(item.ExistingThumbnailPath))
                                            {
                                                <img src="@item.ExistingThumbnailPath" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-image"></i>
                                            }
                                        </div>
                                    </td>

                                    <!-- TITLE -->
                                    <td class="fw-bold text-dark">
                                        @item.Title
                                    </td>

                                    <!-- CATEGORY -->
                                    <td>
                                        <span class="badge-cat">
                                            @(string.IsNullOrWhiteSpace(item.Category) ? "N/A" : item.Category)
                                        </span>
                                    </td>

                                    <!-- LEVEL -->
                                    <td>
                                        <span class="badge-lvl">
                                            @(string.IsNullOrWhiteSpace(item.Level) ? "N/A" : item.Level)
                                        </span>
                                    </td>

                                    <!-- FILE -->
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(item.ExistingFilePath))
                                        {
                                            <a href="@item.ExistingFilePath" target="_blank" class="download-icon">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">---</span>
                                        }
                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-end">
                                        <div class="action-group">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn-action-edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>

                                            <form asp-action="Archive" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn-action-archive">
                                                    <i class="bi bi-archive-fill"></i>
                                                </button>
                                            </form>

                                            <button onclick="confirmDelete(@item.Id)" class="btn-action-delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>

                                        </div>
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 empty-state">
                                    <i class="bi bi-book"></i>
                                    <p>Aucun cours disponible</p>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</section>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(id) {
        Swal.fire({
        title: 'Supprimer ce cours ?',
        text: "Action irréversible.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#20c997',
        cancelButtonColor: '#ef4444',
        confirmButtonText: 'Oui',
        cancelButtonText: 'Annuler'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteForm').submit();
        }
        });
        }
    </script>
}