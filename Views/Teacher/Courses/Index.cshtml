@using Acadimy.ViewModels.Teacher
@model List<TeacherCourseViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Gestion des cours";
}

<div class="container teacher-settings-page">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="settings-title mb-0">Gestion de mes cours</h2>
            <p class="text-muted small mb-0">Consultez et gérez vos publications éducatives</p>
        </div>

        <a asp-action="Create" class="btn-add-course">
            <i class="bi bi-plus-lg me-2"></i> Ajouter un nouveau cours
        </a>
    </div>

    <div class="course-management-card">
        <div class="table-responsive">
            <table class="table acadimy-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Titre du cours</th>
                        <th>Catégorie</th>
                        <th>Niveau</th>
                        <th class="text-center">Fichier</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="rounded shadow-sm bg-light d-flex align-items-center justify-content-center"
                                         style="width: 65px; height: 42px; overflow: hidden; border: 1px solid #eee;">
                                        @if (!string.IsNullOrEmpty(item.ExistingThumbnailPath))
                                        {
                                            <img src="@item.ExistingThumbnailPath"
                                                 style="width: 100%; height: 100%; object-fit: cover;"
                                                 alt="Course Image" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-image text-secondary"></i>
                                        }
                                    </div>
                                </td>

                                <td class="fw-bold text-dark">
                                    @item.Title
                                </td>

                                <td>
                                    <span class="badge-cat">
                                        @(string.IsNullOrWhiteSpace(item.Category) ? "N/A" : item.Category)
                                    </span>
                                </td>

                                <td>
                                    <span class="badge-lvl">
                                        @(string.IsNullOrWhiteSpace(item.Level) ? "N/A" : item.Level)
                                    </span>
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ExistingFilePath))
                                    {
                                        <a href="@item.ExistingFilePath"
                                           target="_blank"
                                           class="text-success"
                                           title="Télécharger">
                                            <i class="bi bi-download fs-5"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">---</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="action-group">

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn-action-edit"
                                           title="Modifier">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>

                                        <form asp-action="Archive" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit"
                                                    class="btn-action-archive"
                                                    title="Archiver">
                                                <i class="bi bi-archive-fill"></i>
                                            </button>
                                        </form>

                                        <button type="button"
                                                onclick="confirmDelete(@item.Id)"
                                                class="btn-action-delete"
                                                title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-book fs-1 mb-3 d-block" style="opacity: 0.3;"></i>
                                <p class="mb-0">Vous n'avez aucun cours pour le moment.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(id) {
        Swal.fire({
        title: 'Supprimer ce cours ?',
        text: "Cette action supprimera définitivement le cours.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#28a745',
        cancelButtonColor: '#e11d48',
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler',
        padding: '2em'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteForm').submit();
        }
        });
        }
    </script>
}