@using Acadimy.ViewModels.Teacher
@using Acadimy.Models.Teacher
@model TeacherCourseViewModel

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Modifier le cours";
    var lessons = ViewBag.Lessons as List<CourseLesson> ?? new List<CourseLesson>();
}

<section class="teacher-form-page">
    <div class="teacher-form-container">

        <div class="teacher-form-header">
            <a asp-controller="TeacherCourses" asp-action="Index" class="teacher-back-btn">
                <i class="bi bi-arrow-left"></i>
            </a>

            <div>
                <span class="teacher-form-badge">COURSE MANAGEMENT</span>
                <h1>Modifier le cours</h1>
                <p>Mettez à jour votre contenu pédagogique.</p>
            </div>
        </div>

        <form asp-controller="TeacherCourses"
              asp-action="Edit"
              asp-route-id="@Model.Id"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ExistingThumbnailPath" />
            <input type="hidden" asp-for="ExistingFilePath" />

            <div class="teacher-form-card mb-4">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-12">
                        <label asp-for="Title" class="teacher-label">Titre du cours</label>
                        <input asp-for="Title" class="form-control teacher-input" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Category" class="teacher-label">Catégorie</label>
                        <input asp-for="Category" class="form-control teacher-input" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Level" class="teacher-label">Niveau</label>
                        <select asp-for="Level" class="form-control teacher-input">
                            <option value="">-- Choisir --</option>
                            <option value="Débutant">Débutant</option>
                            <option value="Intermédiaire">Intermédiaire</option>
                            <option value="Avancé">Avancé</option>
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="teacher-label">Description</label>
                        <textarea asp-for="Description" class="form-control teacher-input teacher-textarea" rows="5"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Thumbnail" class="teacher-label">Changer l'image</label>

                        @if (!string.IsNullOrEmpty(Model.ExistingThumbnailPath))
                        {
                            <div class="current-file-preview">
                                <img src="@Model.ExistingThumbnailPath" />
                                <span>Image actuelle</span>
                            </div>
                        }

                        <input asp-for="Thumbnail" type="file" class="form-control teacher-input" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CourseFile" class="teacher-label">Changer le document</label>

                        @if (!string.IsNullOrEmpty(Model.ExistingFilePath))
                        {
                            <div class="current-file-box">
                                <i class="bi bi-file-earmark-check-fill"></i>
                                <span>Fichier actuel présent</span>
                            </div>
                        }

                        <input asp-for="CourseFile" type="file" class="form-control teacher-input" />
                    </div>
                </div>

                <div class="teacher-form-actions">
                    <a asp-controller="TeacherCourses" asp-action="Index" class="teacher-btn-cancel">
                        Annuler
                    </a>

                    <button type="submit" class="teacher-btn-save">
                        <i class="bi bi-save me-2"></i> Enregistrer les modifications
                    </button>
                </div>
            </div>
        </form>

        <div class="teacher-form-card">
            <div class="lesson-header">
                <div>
                    <span class="teacher-form-badge">LESSONS</span>
                    <h3>Lessons du cours</h3>
                </div>
            </div>

            <form asp-controller="TeacherCourses"
                  asp-action="AddLesson"
                  method="post"
                  class="row g-3 mb-4">

                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@Model.Id" />

                <div class="col-md-5">
                    <input name="title"
                           class="form-control teacher-input"
                           placeholder="Titre de lesson" />
                </div>

                <div class="col-md-5">
                    <input name="description"
                           class="form-control teacher-input"
                           placeholder="Description courte" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="teacher-btn-save w-100">
                        Ajouter
                    </button>
                </div>
            </form>

            @if (lessons.Any())
            {
                <div class="lesson-list">
                    @foreach (var lesson in lessons)
                    {
                        <div class="lesson-item">
                            <div>
                                <strong>@lesson.Order. @lesson.Title</strong>
                                <p>@lesson.Description</p>
                            </div>

                            <form asp-controller="TeacherCourses"
                                  asp-action="DeleteLesson"
                                  method="post"
                                  class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lessonId" value="@lesson.Id" />

                                <button type="submit" class="lesson-delete-btn">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="lesson-empty">
                    Aucune lesson pour ce cours.
                </div>
            }
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}