@model List<Acadimy.ViewModels.Teacher.TeacherPostViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    string? currentUserId = ViewBag.CurrentUserId?.ToString();
}

<div class="teacher-profile-page">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card profile-card-box mb-4">
                <div class="card-body p-4">
                    <h2 class="profile-section-title mb-2">Community</h2>
                    <p class="text-muted mb-0">
                        Discover posts from teachers with similar interests and specialities.
                    </p>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                @foreach (var post in Model)
                {
                    <div class="fb-post-card mb-3">
                        <div class="fb-post-header">
                            <div class="fb-post-user">
                                <a asp-controller="TeacherProfile"
                                   asp-action="ViewProfile"
                                   asp-route-id="@post.UserId"
                                   style="text-decoration:none;">
                                    <img src="@(string.IsNullOrEmpty(post.ProfileImagePath) ? "/images/default-user.png" : post.ProfileImagePath)"
                                         class="fb-post-avatar"
                                         alt="User Avatar" />
                                </a>

                                <div>
                                    <a asp-controller="TeacherProfile"
                                       asp-action="ViewProfile"
                                       asp-route-id="@post.UserId"
                                       style="text-decoration:none; color:inherit;">
                                        <div class="fb-post-name">@post.FullName</div>
                                    </a>
                                    <div class="fb-post-date">@post.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                                </div>
                            </div>
                        </div>

                        <div class="fb-post-body">
                            @if (!string.IsNullOrWhiteSpace(post.Content))
                            {
                                <p class="fb-post-text">@post.Content</p>
                            }

                            @if (!string.IsNullOrEmpty(post.ImagePath))
                            {
                                <img src="@post.ImagePath" class="fb-post-image" alt="Post Image" />
                            }
                        </div>

                        <div class="fb-post-actions">
                            <form asp-controller="TeacherPosts"
                                  asp-action="Like"
                                  method="post"
                                  class="m-0 flex-fill">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="postId" value="@post.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="fb-action-btn w-100">
                                    @(post.IsLikedByCurrentUser ? "💙 Liked" : "👍 Like") (@post.LikesCount)
                                </button>
                            </form>

                            <button type="button"
                                    class="fb-action-btn flex-fill"
                                    onclick="toggleCommentBox('comment-@post.Id')">
                                💬 Comment (@(post.Comments?.Count ?? 0))
                            </button>
                        </div>

                        <div class="fb-comment-box p-3"
                             id="comment-@post.Id"
                             style="display:none; background:#f8f9fa;">

                            <form asp-controller="TeacherPosts"
                                  asp-action="AddComment"
                                  method="post"
                                  class="mb-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="postId" value="@post.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <input type="text"
                                       name="content"
                                       class="form-control fb-comment-input"
                                       placeholder="Write a comment..." />
                            </form>

                            @if (post.Comments != null && post.Comments.Any())
                            {
                                @foreach (var comment in post.Comments)
                                {
                                    <div class="d-flex gap-2 mb-3">
                                        <a asp-controller="TeacherProfile"
                                           asp-action="ViewProfile"
                                           asp-route-id="@comment.UserId"
                                           style="text-decoration:none;">
                                            <img src="@(string.IsNullOrEmpty(comment.ProfileImagePath) ? "/images/default-user.png" : comment.ProfileImagePath)"
                                                 class="fb-comment-avatar"
                                                 alt="Comment Avatar" />
                                        </a>

                                        <div class="fb-comment-content w-100">
                                            <a asp-controller="TeacherProfile"
                                               asp-action="ViewProfile"
                                               asp-route-id="@comment.UserId"
                                               style="text-decoration:none; color:inherit;">
                                                <div class="fb-comment-name">@comment.FullName</div>
                                            </a>

                                            <div class="fb-comment-text">@comment.Content</div>
                                            <div class="fb-comment-date">@comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>

                                            <div class="d-flex gap-2 mt-2">
                                                <form asp-controller="TeacherPosts"
                                                      asp-action="LikeComment"
                                                      method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                                        @(comment.IsLikedByCurrentUser ? "💙 Liked" : "👍 Like") (@comment.LikesCount)
                                                    </button>
                                                </form>

                                                <button type="button"
                                                        class="btn btn-sm btn-outline-secondary"
                                                        onclick="toggleReplyBox('reply-@comment.Id')">
                                                    Reply
                                                </button>

                                                @if (currentUserId == comment.UserId || currentUserId == post.UserId)
                                                {
                                                    <form asp-controller="TeacherPosts"
                                                          asp-action="DeleteComment"
                                                          method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commentId" value="@comment.Id" />
                                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            Delete
                                                        </button>
                                                    </form>
                                                }
                                            </div>

                                            <div id="reply-@comment.Id" class="mt-2" style="display:none;">
                                                <form asp-controller="TeacherPosts"
                                                      asp-action="ReplyComment"
                                                      method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="postId" value="@post.Id" />
                                                    <input type="hidden" name="parentCommentId" value="@comment.Id" />
                                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                    <input type="text"
                                                           name="content"
                                                           class="form-control form-control-sm"
                                                           placeholder="Write a reply..." />
                                                </form>
                                            </div>

                                            @if (comment.Replies != null && comment.Replies.Any())
                                            {
                                                <div class="mt-3 ms-4 border-start ps-3">
                                                    @foreach (var reply in comment.Replies)
                                                    {
                                                        <div class="d-flex gap-2 mb-2">
                                                            <a asp-controller="TeacherProfile"
                                                               asp-action="ViewProfile"
                                                               asp-route-id="@reply.UserId"
                                                               style="text-decoration:none;">
                                                                <img src="@(string.IsNullOrEmpty(reply.ProfileImagePath) ? "/images/default-user.png" : reply.ProfileImagePath)"
                                                                     class="fb-comment-avatar"
                                                                     alt="Reply Avatar" />
                                                            </a>

                                                            <div class="fb-comment-content w-100">
                                                                <a asp-controller="TeacherProfile"
                                                                   asp-action="ViewProfile"
                                                                   asp-route-id="@reply.UserId"
                                                                   style="text-decoration:none; color:inherit;">
                                                                    <div class="fb-comment-name">@reply.FullName</div>
                                                                </a>

                                                                <div class="fb-comment-text">@reply.Content</div>
                                                                <div class="fb-comment-date">@reply.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>

                                                                <div class="d-flex gap-2 mt-2">
                                                                    <form asp-controller="TeacherPosts"
                                                                          asp-action="LikeComment"
                                                                          method="post">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="commentId" value="@reply.Id" />
                                                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                                                            @(reply.IsLikedByCurrentUser ? "💙 Liked" : "👍 Like") (@reply.LikesCount)
                                                                        </button>
                                                                    </form>

                                                                    @if (currentUserId == reply.UserId || currentUserId == post.UserId)
                                                                    {
                                                                        <form asp-controller="TeacherPosts"
                                                                              asp-action="DeleteComment"
                                                                              method="post">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="commentId" value="@reply.Id" />
                                                                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                                Delete
                                                                            </button>
                                                                        </form>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted small mb-0">No comments yet.</p>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card profile-card-box mb-4">
                    <div class="card-body p-4">
                        <p class="mb-0 text-muted">No similar posts found yet.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleCommentBox(id) {
            const box = document.getElementById(id);
            if (!box) return;
            box.style.display = (box.style.display === "none" || box.style.display === "") ? "block" : "none";
        }

        function toggleReplyBox(id) {
            const box = document.getElementById(id);
            if (!box) return;
            box.style.display = (box.style.display === "none" || box.style.display === "") ? "block" : "none";
        }
    </script>
}