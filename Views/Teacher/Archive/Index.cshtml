@using Acadimy.ViewModels.Teacher
@model TeacherArchiveViewModel

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Archive";
}

<section class="teacher-white-page">
    <div class="teacher-white-container">

        <!-- HEADER -->
        <div class="teacher-page-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <span class="page-badge">ARCHIVE</span>
                <h1>Archive</h1>
                <p>Retrouvez vos cours et publications archivés</p>
            </div>

            <a asp-controller="TeacherProfile"
               asp-action="Index"
               class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-2"></i> Retour
            </a>
        </div>

        <!-- POSTS -->
        <div class="card settings-card mb-4">
            <div class="card-body p-4">

                <h3 class="profile-section-title mb-4">Posts archivés</h3>

                @if (Model.ArchivedPosts != null && Model.ArchivedPosts.Any())
                {
                    <div class="row">
                        @foreach (var post in Model.ArchivedPosts)
                        {
                            <div class="col-md-6 mb-4">
                                <div class="archive-post-card">

                                    <div class="archive-post-header">
                                        <img src="@(string.IsNullOrEmpty(post.ProfileImagePath) ? "/images/default-user.png" : post.ProfileImagePath)"
                                             class="archive-avatar" />

                                        <div>
                                            <strong>@post.FullName</strong>
                                            <div class="text-muted small">@post.CreatedAt.ToString("dd MMM yyyy")</div>
                                        </div>
                                    </div>

                                    <div class="archive-post-body">
                                        <p>@post.Content</p>

                                        @if (!string.IsNullOrEmpty(post.ImagePath))
                                        {
                                            <img src="@post.ImagePath" class="archive-post-img" />
                                        }
                                    </div>

                                    <div class="d-flex gap-2 mt-3">
                                        <form asp-controller="TeacherPosts" asp-action="Restore" method="post" class="w-50">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="postId" value="@post.Id" />

                                            <button class="btn btn-outline-success w-100 rounded-pill">
                                                Restore
                                            </button>
                                        </form>

                                        <form asp-controller="TeacherPosts" asp-action="Delete" method="post" class="w-50">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="postId" value="@post.Id" />

                                            <button class="btn btn-outline-danger w-100 rounded-pill">
                                                Delete
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Aucun post archivé.</p>
                }

            </div>
        </div>

        <!-- COURSES -->
        <div class="card settings-card">
            <div class="card-body p-4">

                <h3 class="profile-section-title mb-4">Cours archivés</h3>

                @if (Model.ArchivedCourses != null && Model.ArchivedCourses.Any())
                {
                    <div class="row">
                        @foreach (var item in Model.ArchivedCourses)
                        {
                            <div class="col-md-4 mb-4">
                                <div class="archive-course-card">

                                    <img src="@(string.IsNullOrEmpty(item.ExistingThumbnailPath) ? "/images/default-course.jpg" : item.ExistingThumbnailPath)"
                                         class="archive-course-img" />

                                    <div class="p-3">

                                        <span class="badge-cat">@item.Category</span>

                                        <h5 class="mt-2">@item.Title</h5>

                                        <small class="text-muted">
                                            @item.CreatedAt.ToString("dd MMM yyyy")
                                        </small>

                                        <div class="d-flex justify-content-between mt-3">

                                            <form asp-controller="TeacherCourses" asp-action="Restore" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button class="btn-action-restore">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            </form>

                                            <form asp-controller="TeacherCourses" asp-action="Delete" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button class="btn-action-delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>

                                        </div>

                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Aucun cours archivé.</p>
                }

            </div>
        </div>

    </div>
</section>