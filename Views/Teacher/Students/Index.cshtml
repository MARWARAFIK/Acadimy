@model Acadimy.ViewModels.Teacher.TeacherStudentsPageViewModel

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Students";
}

<section class="teacher-page">
    <div class="teacher-page-container">

        <div class="teacher-page-header">
            <div>
                <span class="page-badge">STUDENTS</span>
                <h1>Gestion de mes étudiants</h1>
                <p>Suivez la progression automatiquement selon les leçons terminées.</p>
            </div>
        </div>

        <form asp-controller="TeacherStudents" asp-action="Index" method="get" class="teacher-filter-card-modern">
            <div class="filter-input-modern">
                <i class="bi bi-search"></i>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       placeholder="Chercher étudiant, email ou cours..." />
            </div>

            <select name="courseId" class="filter-select-modern">
                <option value="">Tous les cours</option>
                @foreach (var course in Model.Courses)
                {
                    <option value="@course.Id" selected="@(Model.CourseId == course.Id)">
                        @course.Title
                    </option>
                }
            </select>

            <button type="submit" class="filter-btn-modern">
                <i class="bi bi-funnel"></i> Filtrer
            </button>
        </form>

        @if (Model.Students != null && Model.Students.Any())
        {
            <div class="teacher-card">
                <div class="table-responsive">
                    <table class="table teacher-table align-middle">
                        <thead>
                            <tr>
                                <th>Étudiant</th>
                                <th>Cours</th>
                                <th>Niveau</th>
                                <th>Inscrit le</th>
                                <th>Progression</th>
                                <th>Statut</th>
                                <th>Gestion</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var student in Model.Students)
                            {
                                var statusClass = student.Status == "Completed"
                                    ? "completed"
                                    : student.Status == "Paused"
                                        ? "paused"
                                        : "";

                                var isPaused = student.Status == "Paused";
                                var btnClass = isPaused ? "pause-btn-modern resume" : "pause-btn-modern";
                                var btnText = isPaused ? "Resume" : "Pause";
                                var iconClass = isPaused ? "bi bi-play-fill" : "bi bi-pause-fill";

                                <tr id="student-row-@student.EnrollmentId">
                                    <td>
                                        <a asp-controller="Profile"
                                           asp-action="Index"
                                           asp-route-id="@student.StudentId"
                                           class="student-mini-profile">

                                            <img src="@(string.IsNullOrEmpty(student.ProfileImagePath) ? "/images/default-user.png" : student.ProfileImagePath)" />

                                            <div>
                                                <strong>@student.FullName</strong>
                                                <small>@student.Email</small>
                                            </div>
                                        </a>
                                    </td>

                                    <td>
                                        <span class="badge-cat">@student.CourseTitle</span>
                                    </td>

                                    <td>
                                        <span class="badge-lvl">@student.Level</span>
                                    </td>

                                    <td>@student.EnrolledAt.ToString("dd/MM/yyyy")</td>

                                    <td>
                                        <div class="progress-wrap">
                                            <div class="progress">
                                                <div class="progress-bar" style="width:@(student.ProgressPercent)%"></div>
                                            </div>
                                            <small>@student.ProgressPercent%</small>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="status-badge @statusClass" id="status-badge-@student.EnrollmentId">
                                            @student.Status
                                        </span>
                                    </td>

                                    <td>
                                        @if (student.Status != "Completed")
                                        {
                                            <form class="pause-form" data-enrollment-id="@student.EnrollmentId">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="enrollmentId" value="@student.EnrollmentId" />

                                                <button type="button"
                                                        class="@btnClass"
                                                        data-enrollment-id="@student.EnrollmentId">
                                                    <i class="@iconClass"></i>
                                                    @btnText
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Auto</span>
                                        }
                                    </td>

                                    <td>
                                        <a asp-controller="TeacherStudents"
                                           asp-action="Details"
                                           asp-route-id="@student.EnrollmentId"
                                           class="btn-student-action-modern">
                                            Détails
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="teacher-card empty-state text-center py-5">
                <i class="bi bi-people"></i>
                <p>Aucun étudiant pour le moment.</p>
            </div>
        }

    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".pause-btn-modern").forEach(function (button) {
                button.addEventListener("click", async function () {
                    const enrollmentId = this.dataset.enrollmentId;
                    const form = this.closest("form");
                    const token = form.querySelector('input[name="__RequestVerificationToken"]').value;

                    const formData = new FormData();
                    formData.append("enrollmentId", enrollmentId);
                    formData.append("__RequestVerificationToken", token);

                    this.disabled = true;

                    const response = await fetch("/TeacherStudents/TogglePauseAjax", {
                        method: "POST",
                        body: formData
                    });

                    const result = await response.json();
                    this.disabled = false;

                    if (!result.success) {
                        alert(result.message || "Erreur");
                        return;
                    }

                    const badge = document.getElementById("status-badge-" + enrollmentId);
                    badge.textContent = result.status;
                    badge.classList.remove("completed", "paused");

                    if (result.status === "Paused") {
                        badge.classList.add("paused");
                        this.className = "pause-btn-modern resume";
                        this.innerHTML = '<i class="bi bi-play-fill"></i> Resume';
                    } else {
                        this.className = "pause-btn-modern";
                        this.innerHTML = '<i class="bi bi-pause-fill"></i> Pause';
                    }
                });
            });
        });
    </script>
}