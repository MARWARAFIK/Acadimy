@using Acadimy.ViewModels.Teacher
@model TeacherAssignmentViewModel

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Créer assignment";
}

<section class="teacher-form-page">
    <div class="teacher-form-container">

        <div class="teacher-form-header">
            <a asp-action="Index" class="teacher-back-btn">
                <i class="bi bi-arrow-left"></i>
            </a>

            <div>
                <span class="teacher-form-badge">ASSIGNMENT</span>
                <h1>Créer un assignment</h1>
                <p>Publiez un devoir pour vos étudiants</p>
            </div>
        </div>

        <div class="teacher-form-card">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row g-4">
                    <div class="col-md-12">
                        <label asp-for="Title" class="teacher-label">Titre</label>
                        <input asp-for="Title" class="form-control teacher-input" placeholder="Ex: TP ASP.NET Core MVC" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TeacherCourseId" class="teacher-label">Cours</label>
                        <select asp-for="TeacherCourseId" asp-items="ViewBag.Courses" class="form-control teacher-input">
                            <option value="">-- Choisir un cours --</option>
                        </select>
                        <span asp-validation-for="TeacherCourseId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Deadline" class="teacher-label">Deadline</label>
                        <input asp-for="Deadline" type="datetime-local" class="form-control teacher-input" />
                        <span asp-validation-for="Deadline" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="teacher-label">Description</label>
                        <textarea asp-for="Description"
                                  class="form-control teacher-input teacher-textarea"
                                  rows="5"
                                  placeholder="Expliquez le travail demandé..."></textarea>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="AssignmentFile" class="teacher-label">Fichier</label>
                        <input asp-for="AssignmentFile" type="file" class="form-control teacher-input" />
                        <small class="text-muted">PDF, DOCX, ZIP...</small>
                    </div>
                </div>

                <div class="teacher-form-actions">
                    <a asp-action="Index" class="teacher-btn-cancel">
                        Annuler
                    </a>

                    <button type="submit" class="teacher-btn-save">
                        <i class="bi bi-check-lg me-2"></i> Enregistrer
                    </button>
                </div>
            </form>
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}