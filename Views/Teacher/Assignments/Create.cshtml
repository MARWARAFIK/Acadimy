@using Acadimy.ViewModels.Teacher
@model TeacherAssignmentViewModel

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Créer assignment";
}

<div class="container teacher-settings-page">

    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-light rounded-pill shadow-sm me-3 px-3 py-2">
            <i class="bi bi-arrow-left"></i>
        </a>

        <div>
            <h2 class="settings-title mb-0">Créer un assignment</h2>
            <p class="text-muted small mb-0">Publiez un devoir pour vos étudiants</p>
        </div>
    </div>

    <div class="course-management-card p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold">Titre</label>
                <input asp-for="Title" class="form-control" placeholder="Ex: TP ASP.NET Core MVC" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TeacherCourseId" class="form-label fw-bold">Cours</label>
                <select asp-for="TeacherCourseId" asp-items="ViewBag.Courses" class="form-select">
                    <option value="">-- Choisir un cours --</option>
                </select>
                <span asp-validation-for="TeacherCourseId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Deadline" class="form-label fw-bold">Deadline</label>
                <input asp-for="Deadline" type="datetime-local" class="form-control" />
                <span asp-validation-for="Deadline" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="5"
                          placeholder="Expliquez le travail demandé..."></textarea>
            </div>

            <div class="mb-4">
                <label asp-for="AssignmentFile" class="form-label fw-bold">Fichier</label>
                <input asp-for="AssignmentFile" type="file" class="form-control" />
                <small class="text-muted">PDF, DOCX, ZIP...</small>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-light rounded-pill px-4">
                    Annuler
                </a>

                <button type="submit" class="btn-add-course border-0">
                    <i class="bi bi-check-lg me-2"></i> Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}