@using Acadimy.ViewModels.Teacher
@model List<TeacherAssignmentViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Assignments";
}

<section class="teacher-page">
    <div class="teacher-page-container">

        <div class="teacher-page-header">
            <div>
                <span class="page-badge">ASSIGNMENTS</span>
                <h1>Gestion des assignments</h1>
                <p>Créez et suivez les devoirs de vos étudiants</p>
            </div>

            <a asp-action="Create" class="teacher-btn-main">
                <i class="bi bi-plus-lg me-2"></i> Nouveau assignment
            </a>
        </div>

        <div class="teacher-card">
            <div class="table-responsive">
                <table class="table teacher-table align-middle">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Cours</th>
                            <th>Deadline</th>
                            <th class="text-center">Fichier</th>
                            <th class="text-center">Submissions</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Title</div>
                                        <div class="small text-muted">
                                            @(string.IsNullOrWhiteSpace(item.Description)
                                                ? "Aucune description"
                                                : item.Description)
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge-cat">@item.CourseTitle</span>
                                    </td>

                                    <td>
                                        @if (item.Deadline < DateTime.Now)
                                        {
                                            <span class="assignment-status expired">
                                                Expired - @item.Deadline.ToString("dd/MM/yyyy HH:mm")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="assignment-status open">
                                                Open - @item.Deadline.ToString("dd/MM/yyyy HH:mm")
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(item.ExistingFilePath))
                                        {
                                            <a href="@item.ExistingFilePath" target="_blank" class="download-icon">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">---</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <a asp-action="Submissions"
                                           asp-route-id="@item.Id"
                                           class="submission-badge">
                                            @item.SubmissionsCount
                                        </a>
                                    </td>

                                    <td class="text-end">
                                        <div class="action-group">
                                            <a asp-action="Submissions"
                                               asp-route-id="@item.Id"
                                               class="btn-action-edit"
                                               title="Voir submissions">
                                                <i class="bi bi-inbox-fill"></i>
                                            </a>

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn-action-edit"
                                               title="Modifier">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>

                                            <form asp-action="Archive" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn-action-archive" title="Archiver">
                                                    <i class="bi bi-archive-fill"></i>
                                                </button>
                                            </form>

                                            <button type="button"
                                                    onclick="confirmDelete(@item.Id)"
                                                    class="btn-action-delete"
                                                    title="Supprimer">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 empty-state">
                                    <i class="bi bi-file-earmark-check"></i>
                                    <p>Aucun assignment pour le moment.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(id) {
        Swal.fire({
        title: 'Supprimer cet assignment ?',
        text: "Cette action est définitive.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#20c997',
        cancelButtonColor: '#ef4444',
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteForm').submit();
        }
        });
        }
    </script>
}