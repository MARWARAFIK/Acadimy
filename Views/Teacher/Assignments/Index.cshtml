@using Acadimy.ViewModels.Teacher
@model List<TeacherAssignmentViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Assignments";
}

<div class="container teacher-settings-page">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="settings-title mb-0">Gestion des assignments</h2>
            <p class="text-muted small mb-0">Créez et suivez les devoirs de vos étudiants</p>
        </div>

        <a asp-action="Create" class="btn-add-course">
            <i class="bi bi-plus-lg me-2"></i> Nouveau assignment
        </a>
    </div>

    <div class="course-management-card">
        <div class="table-responsive">
            <table class="table acadimy-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Cours</th>
                        <th>Deadline</th>
                        <th class="text-center">Fichier</th>
                        <th class="text-center">Submissions</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@item.Title</div>
                                    <div class="small text-muted">
                                        @(string.IsNullOrWhiteSpace(item.Description)
                                            ? "Aucune description"
                                            : item.Description)
                                    </div>
                                </td>

                                <td>
                                    <span class="badge-cat">@item.CourseTitle</span>
                                </td>

                                <td>
                                    @if (item.Deadline < DateTime.Now)
                                    {
                                        <span class="badge bg-danger rounded-pill">
                                            Expired - @item.Deadline.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill">
                                            Open - @item.Deadline.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ExistingFilePath))
                                    {
                                        <a href="@item.ExistingFilePath" target="_blank" class="text-success">
                                            <i class="bi bi-download fs-5"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">---</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <a asp-action="Submissions"
                                       asp-route-id="@item.Id"
                                       class="badge bg-primary rounded-pill text-decoration-none">
                                        @item.SubmissionsCount
                                    </a>
                                </td>

                                <td class="text-end">
                                    <div class="action-group">

                                        <a asp-action="Submissions"
                                           asp-route-id="@item.Id"
                                           class="btn-action-edit"
                                           title="Voir submissions">
                                            <i class="bi bi-inbox-fill"></i>
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn-action-edit"
                                           title="Modifier">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>

                                        <form asp-action="Archive" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit"
                                                    class="btn-action-archive"
                                                    title="Archiver">
                                                <i class="bi bi-archive-fill"></i>
                                            </button>
                                        </form>

                                        <button type="button"
                                                onclick="confirmDelete(@item.Id)"
                                                class="btn-action-delete"
                                                title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-file-earmark-check fs-1 mb-3 d-block" style="opacity: 0.3;"></i>
                                <p class="mb-0">Vous n'avez aucun assignment pour le moment.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDelete(id) {
        Swal.fire({
        title: 'Supprimer cet assignment ?',
        text: "Cette action est définitive.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#28a745',
        cancelButtonColor: '#e11d48',
        confirmButtonText: 'Oui, supprimer',
        cancelButtonText: 'Annuler'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('deleteId').value = id;
        document.getElementById('deleteForm').submit();
        }
        });
        }
    </script>
}