@using Acadimy.ViewModels.Teacher
@model List<TeacherAssignmentSubmissionViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Submissions";
}

<section class="teacher-page">
    <div class="teacher-page-container">

        <!-- HEADER -->
        <div class="teacher-page-header">
            <div class="d-flex align-items-center gap-3">

                <a asp-action="Index" class="teacher-back-btn">
                    <i class="bi bi-arrow-left"></i>
                </a>

                <div>
                    <span class="page-badge">SUBMISSIONS</span>
                    <h1>Submissions</h1>
                    <p>
                        Assignment: <strong>@ViewBag.AssignmentTitle</strong> —
                        Cours: <strong>@ViewBag.CourseTitle</strong>
                    </p>
                </div>
            </div>
        </div>

        <!-- ALERTS -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success teacher-alert">
                <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger teacher-alert">
                <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
            </div>
        }

        <!-- TABLE -->
        <div class="teacher-card">
            <div class="table-responsive">

                <table class="table teacher-table align-middle">

                    <thead>
                        <tr>
                            <th>Étudiant</th>
                            <th>Commentaire</th>
                            <th>Date</th>
                            <th class="text-center">Fichier</th>
                            <th style="width:260px;">Note / Feedback</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- STUDENT -->
                                    <td>
                                        <div class="student-box">
                                            <div class="student-avatar">
                                                @if (!string.IsNullOrEmpty(item.ProfileImagePath))
                                                {
                                                    <img src="@item.ProfileImagePath" />
                                                }
                                                else
                                                {
                                                    <i class="bi bi-person"></i>
                                                }
                                            </div>

                                            <div>
                                                <div class="fw-bold text-dark">
                                                    @(string.IsNullOrWhiteSpace(item.StudentName) ? "Étudiant" : item.StudentName)
                                                </div>
                                                <div class="small text-muted">@item.StudentEmail</div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- COMMENT -->
                                    <td class="text-muted">
                                        @(string.IsNullOrWhiteSpace(item.Comment) ? "Aucun commentaire" : item.Comment)
                                    </td>

                                    <!-- DATE -->
                                    <td>
                                        <span class="badge-lvl">
                                            @item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>

                                    <!-- FILE -->
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(item.FilePath))
                                        {
                                            <a href="@item.FilePath" target="_blank" class="download-icon">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">---</span>
                                        }
                                    </td>

                                    <!-- GRADE -->
                                    <td>
                                        <form asp-action="GradeSubmission" method="post">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="submissionId" value="@item.SubmissionId" />

                                            <input type="number"
                                                   name="grade"
                                                   value="@item.Grade"
                                                   class="form-control teacher-input mb-2"
                                                   placeholder="Note /20" />

                                            <textarea name="teacherFeedback"
                                                      class="form-control teacher-input"
                                                      rows="2"
                                                      placeholder="Feedback...">@item.TeacherFeedback</textarea>

                                            <button type="submit" class="teacher-btn-save mt-2 w-100">
                                                Save
                                            </button>
                                        </form>
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 empty-state">
                                    <i class="bi bi-inbox"></i>
                                    <p>Aucune submission pour le moment.</p>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>

    </div>
</section>