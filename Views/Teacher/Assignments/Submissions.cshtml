@using Acadimy.ViewModels.Teacher
@model List<TeacherAssignmentSubmissionViewModel>

@{
    Layout = "~/Views/Shared/LayoutTeacher.cshtml";
    ViewData["Title"] = "Submissions";
}

<div class="container teacher-settings-page">

    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-light rounded-pill shadow-sm me-3 px-3 py-2">
            <i class="bi bi-arrow-left"></i>
        </a>

        <div>
            <h2 class="settings-title mb-0">Submissions</h2>
            <p class="text-muted small mb-0">
                Assignment: <strong>@ViewBag.AssignmentTitle</strong>
                —
                Cours: <strong>@ViewBag.CourseTitle</strong>
            </p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 shadow-sm">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="course-management-card">
        <div class="table-responsive">
            <table class="table acadimy-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Commentaire</th>
                        <th>Date</th>
                        <th class="text-center">Fichier</th>
                        <th style="width: 260px;">Note / Feedback</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
                                             style="width:42px;height:42px;overflow:hidden;border:1px solid #eee;">
                                            @if (!string.IsNullOrEmpty(item.ProfileImagePath))
                                            {
                                                <img src="@item.ProfileImagePath"
                                                     style="width:100%;height:100%;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-person text-secondary"></i>
                                            }
                                        </div>

                                        <div>
                                            <div class="fw-bold text-dark">
                                                @(string.IsNullOrWhiteSpace(item.StudentName) ? "Étudiant" : item.StudentName)
                                            </div>
                                            <div class="small text-muted">@item.StudentEmail</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="small text-muted">
                                        @(string.IsNullOrWhiteSpace(item.Comment) ? "Aucun commentaire" : item.Comment)
                                    </span>
                                </td>

                                <td>
                                    <span class="badge-lvl">
                                        @item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.FilePath))
                                    {
                                        <a href="@item.FilePath" target="_blank" class="text-success">
                                            <i class="bi bi-download fs-5"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">---</span>
                                    }
                                </td>

                                <td>
                                    <form asp-action="GradeSubmission" method="post">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="submissionId" value="@item.SubmissionId" />

                                        <div class="mb-2">
                                            <input type="number"
                                                   step="0.25"
                                                   min="0"
                                                   max="20"
                                                   name="grade"
                                                   value="@item.Grade"
                                                   class="form-control form-control-sm"
                                                   placeholder="Note /20" />
                                        </div>

                                        <div class="mb-2">
                                            <textarea name="teacherFeedback"
                                                      class="form-control form-control-sm"
                                                      rows="2"
                                                      placeholder="Feedback...">@item.TeacherFeedback</textarea>
                                        </div>

                                        <button type="submit" class="btn btn-success btn-sm rounded-pill px-3">
                                            <i class="bi bi-check-lg me-1"></i> Save
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 mb-3 d-block" style="opacity: 0.3;"></i>
                                <p class="mb-0">Aucune submission pour le moment.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>