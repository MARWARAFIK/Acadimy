@using System.Security.Claims
@using Acadimy.Models.Messaging
@using Acadimy.Models.Teacher
@model List<MessageThread>

@{
    var isTeacher = User.IsInRole("Enseignant") || User.IsInRole("Teacher");

    Layout = isTeacher
        ? "~/Views/Shared/LayoutTeacher.cshtml"
        : "~/Views/Shared/LayoutStudent.cshtml";

    ViewData["Title"] = "Messages";

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var courseGroups = ViewBag.CourseGroups as List<TeacherCourse> ?? new();
}

<section class="messages-page">
    <div class="messages-wrapper">

        <div class="messages-header">
            <span>MESSAGES</span>
            <h1>Mes conversations</h1>
            <p>Discutez avec vos étudiants, enseignants et groupes de cours.</p>
        </div>

        <div class="messages-grid">

            <div class="messages-card">
                <div class="messages-card-header">
                    <i class="bi bi-chat-dots"></i>
                    <h3>Conversations privées</h3>
                </div>

                @if (Model == null || !Model.Any())
                {
                    <div class="messages-empty">
                        <i class="bi bi-inbox"></i>
                        <p>Aucune conversation.</p>
                    </div>
                }
                else
                {
                    <div class="messages-list">
                        @foreach (var t in Model)
                        {
                            var otherId = t.User1Id == currentUserId ? t.User2Id : t.User1Id;
                            var lastMsg = t.Messages.OrderByDescending(m => m.SentAt).FirstOrDefault();

                            <a asp-controller="Messages"
                               asp-action="Chat"
                               asp-route-userId="@otherId"
                               class="message-item">

                                <div class="message-icon">
                                    <i class="bi bi-person"></i>
                                </div>

                                <div class="message-info">
                                    <strong>Conversation privée</strong>
                                    <p>@(lastMsg?.Content ?? lastMsg?.AttachmentFileName ?? "Aucun message")</p>
                                </div>

                                <i class="bi bi-chevron-right message-arrow"></i>
                            </a>
                        }
                    </div>
                }
            </div>

            <div class="messages-card">
                <div class="messages-card-header">
                    <i class="bi bi-people"></i>
                    <h3>Groupes par cours</h3>
                </div>

                @if (!courseGroups.Any())
                {
                    <div class="messages-empty">
                        <i class="bi bi-journal-x"></i>
                        <p>Aucun groupe disponible.</p>
                    </div>
                }
                else
                {
                    <div class="messages-list">
                        @foreach (var course in courseGroups)
                        {
                            <a asp-controller="Messages"
                               asp-action="CourseGroup"
                               asp-route-courseId="@course.Id"
                               class="message-item">

                                <div class="message-icon course">
                                    <i class="bi bi-journal-bookmark"></i>
                                </div>

                                <div class="message-info">
                                    <strong>@course.Title</strong>
                                    <p>Discussion de groupe du cours</p>
                                </div>

                                <i class="bi bi-chevron-right message-arrow"></i>
                            </a>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
</section>