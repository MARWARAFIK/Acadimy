@using System.Security.Claims
@using Acadimy.Models.Messaging
@model List<CourseGroupMessage>

@{
    var isTeacher = User.IsInRole("Enseignant") || User.IsInRole("Teacher");

    Layout = isTeacher
        ? "~/Views/Shared/LayoutTeacher.cshtml"
        : "~/Views/Shared/LayoutStudent.cshtml";

    ViewData["Title"] = "Groupe";

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var course = ViewBag.Course as Acadimy.Models.Teacher.TeacherCourse;
}

<section class="messages-page">
    <div class="chat-wrapper">

        <div class="chat-header-card">
            <a asp-controller="Messages" asp-action="Index" class="chat-back">
                <i class="bi bi-arrow-left"></i>
            </a>

            <div>
                <span>COURSE GROUP</span>
                <h1>@course?.Title</h1>
                <p>Groupe de discussion du cours</p>
            </div>
        </div>

        <div class="group-chat-box">
            @if (Model == null || !Model.Any())
            {
                <div class="messages-empty">
                    <i class="bi bi-chat-square-dots"></i>
                    <p>Aucun message dans ce groupe.</p>
                </div>
            }
            else
            {
                foreach (var msg in Model)
                {
                    var isMe = msg.SenderId == currentUserId;

                    <div class="group-message-row @(isMe ? "me" : "other")">
                        <div class="group-sender">
                            @(msg.Sender?.FullName ?? "Utilisateur")
                        </div>

                        <div class="group-bubble @(isMe ? "me" : "other")">
                            @if (!string.IsNullOrWhiteSpace(msg.Content))
                            {
                                <div>@msg.Content</div>
                            }

                            @if (!string.IsNullOrWhiteSpace(msg.AttachmentPath))
                            {
                                if (msg.AttachmentContentType?.StartsWith("image/") == true)
                                {
                                    <img src="@msg.AttachmentPath" class="group-chat-img" />
                                }
                                else if (msg.AttachmentContentType?.StartsWith("audio/") == true)
                                {
                                    <audio controls class="group-chat-audio">
                                        <source src="@msg.AttachmentPath" type="@msg.AttachmentContentType" />
                                    </audio>
                                }
                                else
                                {
                                    <a href="@msg.AttachmentPath" target="_blank" class="file-link">
                                        <i class="bi bi-paperclip"></i> @msg.AttachmentFileName
                                    </a>
                                }
                            }
                        </div>

                        <div class="group-time">
                            @msg.SentAt.ToString("dd/MM HH:mm")
                        </div>
                    </div>
                }
            }
        </div>

        <form asp-controller="Messages" asp-action="SendCourseGroup" method="post" enctype="multipart/form-data" class="group-send-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="courseId" value="@course?.Id" />

            <input name="content" class="group-input" placeholder="Écrire dans le groupe..." />

            <input name="attachment"
                   type="file"
                   class="group-file"
                   accept="image/*,.pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,audio/*" />

            <button type="submit" class="group-send-btn">
                <i class="bi bi-send"></i>
            </button>
        </form>

    </div>
</section>