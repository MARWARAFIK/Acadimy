@model Acadimy.ViewModels.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Acadimy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
            body {
                margin: 0;
                min-height: 100vh;
                font-family: 'Segoe UI', sans-serif;
                background: linear-gradient(rgba(10, 25, 47, 0.58), rgba(10, 25, 47, 0.58)), url('https://images.unsplash.com/photo-1497366412874-3415097a27e7?q=80&w=1600&auto=format&fit=crop') center center / cover no-repeat;
            }

            .auth-page {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: flex-start;
                padding: 40px 70px;
            }

            .auth-card {
                width: 100%;
                max-width: 430px;
                background: rgba(255,255,255,0.96);
                border-radius: 20px;
                padding: 26px 26px 22px;
                box-shadow: 0 18px 45px rgba(0,0,0,0.18);
            }

            .auth-logo {
                text-align: center;
                font-size: 18px;
                font-weight: 700;
                color: #111827;
                margin-bottom: 18px;
            }

                .auth-logo i {
                    color: #16a34a;
                    margin-right: 6px;
                }

            .auth-title {
                font-size: 26px;
                font-weight: 700;
                color: #0f172a;
                margin-bottom: 22px;
            }

            .form-label {
                font-size: 15px;
                font-weight: 600;
                color: #0f172a;
                margin-bottom: 8px;
            }

            .form-control, .form-select {
                height: 48px;
                border-radius: 12px;
                border: 1px solid #d6dde7;
                font-size: 15px;
                margin-bottom: 12px;
            }

            .auth-btn {
                width: 100%;
                height: 50px;
                border: none;
                border-radius: 12px;
                background: #16a34a;
                color: #fff;
                font-size: 17px;
                font-weight: 700;
                transition: 0.2s ease;
                margin-top: 10px;
            }

                .auth-btn:hover {
                    background: #15803d;
                }

            .password-box {
                position: relative;
            }

            .toggle-password {
                position: absolute;
                top: 40%; /* Ajusté pour le margin-bottom de l'input */
                right: 12px;
                transform: translateY(-50%);
                border: none;
                background: none;
                color: #64748b;
                cursor: pointer;
            }

            .auth-footer {
                margin-top: 20px;
                text-align: center;
                font-size: 15px;
                color: #64748b;
            }

                .auth-footer a {
                    text-decoration: none;
                    color: #0f172a;
                    font-weight: 700;
                    margin-left: 4px;
                }
    </style>
</head>
<body>
    <div class="auth-page">
        <div class="auth-card">
            <div class="auth-logo"><i class="bi bi-mortarboard-fill"></i> Acadimy</div>
            <h2 class="auth-title">Signup</h2>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                <div class="mb-1">
                    <label asp-for="FirstName" class="form-label">First Name</label>
                    <input asp-for="FirstName" class="form-control" placeholder="Harry" />
                </div>

                <div class="mb-1">
                    <label asp-for="LastName" class="form-label">Last Name</label>
                    <input asp-for="LastName" class="form-control" placeholder="Potter" />
                </div>

                <div class="mb-1">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                </div>

                <div class="mb-1">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="password-box">
                        <input asp-for="Password" type="password" class="form-control" id="pwd" />
                        <button type="button" class="toggle-password" onclick="toggle('pwd')"><i class="bi bi-eye"></i></button>
                    </div>
                </div>

                <div class="mb-1">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <div class="password-box">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" id="cpwd" />
                        <button type="button" class="toggle-password" onclick="toggle('cpwd')"><i class="bi bi-eye"></i></button>
                    </div>
                </div>

                <div class="mb-2">
                    <label asp-for="Role" class="form-label">Role</label>
                    <select asp-for="Role" class="form-select">
                        <option value="">Choose role</option>
                        <option value="Étudiant">Student</option>
                        <option value="Enseignant">Teacher</option>
                    </select>
                </div>

                <button type="submit" class="auth-btn">Register</button>

                <div class="auth-footer">
                    Already have an account? <a asp-action="Login">Sign in</a>
                </div>
            </form>
        </div>
    </div>
    <script>
            function toggle(id) {
                const input = document.getElementById(id);
                input.type = input.type === "password" ? "text" : "password";
            }
    </script>
</body>
</html>