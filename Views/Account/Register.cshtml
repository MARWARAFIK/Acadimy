@model Acadimy.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-container">
    <div class="auth-card signup">

        <div class="auth-logo">Jobstack</div>

        <h2>Signup</h2>

        <form asp-action="Register" method="post">

            <div class="form-group">
                <label>Your Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Harry" />
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Password" type="password" class="form-control" />
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
            </div>

            <div class="form-group">
                <label>Role</label>
                <select asp-for="Role" class="form-control">
                    <option value="Student">Etudiant</option>
                    <option value="Teacher">Enseignant</option>
                </select>
            </div>

            <button class="auth-btn">Register</button>

        </form>

        <div asp-validation-summary="All" style="color:red;"></div>

        <div class="auth-footer">
            Already have an account? <a asp-action="Login">Sign in</a>
        </div>

    </div>
</div>