@model List<Acadimy.Models.Notification>

@{
    var isTeacher = User.IsInRole("Enseignant") || User.IsInRole("Teacher");

    Layout = isTeacher
        ? "~/Views/Shared/LayoutTeacher.cshtml"
        : "~/Views/Shared/LayoutStudent.cshtml";

    ViewData["Title"] = "Notifications";
}

<section class="notifications-page">

    <div class="notifications-wrapper">

        <!-- HEADER -->
        <div class="notifications-header">
            <span>NOTIFICATIONS</span>
            <h1>Mes notifications</h1>
            <p>Restez informé de toutes les activités importantes.</p>
        </div>

        <!-- ERROR -->
        @if (TempData["NotificationError"] != null)
        {
            <div class="notification-alert warning">
                <i class="bi bi-exclamation-triangle me-2"></i>
                @TempData["NotificationError"]
            </div>
        }

        <!-- EMPTY -->
        @if (Model == null || !Model.Any())
        {
            <div class="notification-empty">
                <i class="bi bi-bell-slash"></i>
                <h3>Aucune notification</h3>
                <p>Vous n’avez rien pour le moment.</p>
            </div>
        }
        else
        {
            <!-- LIST -->
            <div class="notifications-list">

                @foreach (var n in Model)
                {
                    var icon = n.Type == "Course"
                        ? "bi bi-journal-bookmark"
                        : n.Type == "Grade"
                            ? "bi bi-check-circle"
                            : "bi bi-bell";

                    <a asp-action="Read"
                       asp-route-id="@n.Id"
                       class="notification-card @(n.IsRead ? "read" : "unread")">

                        <!-- ICON -->
                        <div class="notif-icon">
                            <i class="@icon"></i>
                        </div>

                        <!-- CONTENT -->
                        <div class="notif-content">

                            <div class="notif-header">
                                <strong>
                                    @if (!n.IsRead)
                                    {
                                        <span class="dot"></span>
                                    }
                                    @n.Title
                                </strong>

                                <small>
                                    @n.CreatedAt.ToString("dd/MM HH:mm")
                                </small>
                            </div>

                            <p>@n.Message</p>
                        </div>

                        <!-- ARROW -->
                        <div class="notif-arrow">
                            <i class="bi bi-chevron-right"></i>
                        </div>

                    </a>
                }

            </div>
        }

    </div>

</section>