<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acadimy - Teacher</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/teacher.css" asp-append-version="true" />

    <style>
            .navbar {
                border-bottom: 1px solid #eee;
            }

            .nav-link {
                font-weight: 500;
                color: #4b5563 !important;
                transition: 0.3s;
            }

                .nav-link:hover {
                    color: #16a34a !important;
                }

            .user-icon-btn {
                color: #4b5563;
                font-size: 1.5rem;
                transition: 0.2s;
                cursor: pointer;
            }

                .user-icon-btn:hover {
                    color: #16a34a;
                }

            .dropdown-toggle::after {
                display: none;
            }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">

            <!-- LOGO -->
            <a class="navbar-brand fw-bold" asp-controller="Teacher" asp-action="Index">
                <span style="color: #16a34a;">
                    <i class="bi bi-person-workspace"></i> Acadimy
                </span>
            </a>

            <!-- MOBILE BTN -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTeacher">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENU -->
            <div class="collapse navbar-collapse" id="navbarTeacher">
                <ul class="navbar-nav ms-auto align-items-center">

                    <!-- HOME -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Teacher" asp-action="Index">
                            <i class="bi bi-house"></i> Home
                        </a>
                    </li>

                    <!-- COURSES -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TeacherCourses" asp-action="Index">
                            <i class="bi bi-journals"></i> My Courses
                        </a>
                    </li>
                    <!-- STUDENTS -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TeacherStudents" asp-action="Index">
                            <i class="bi bi-people"></i> Students
                        </a>
                    </li>

                    <!-- ASSIGNMENTS -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Assignments" asp-action="Index">
                            <i class="bi bi-file-earmark-check"></i> Assignments
                        </a>
                    </li>

                    <!-- 🔥 COMMUNITY (NEW) -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TeacherCommunity" asp-action="Index">
                            <i class="bi bi-globe"></i> Community
                        </a>
                    </li>

                    <!-- USER DROPDOWN -->
                    <li class="nav-item dropdown ms-lg-3">
                        <a class="nav-link dropdown-toggle user-icon-btn"
                           href="#"
                           id="teacherUserDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-person-circle"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0"
                            aria-labelledby="teacherUserDropdown">

                            <!-- USER NAME -->
                            <li class="px-3 py-2 small text-muted border-bottom">
                                Enseignant : @User.Identity?.Name
                            </li>

                            <!-- PROFILE -->
                            <li>
                                <a class="dropdown-item py-2"
                                   asp-controller="TeacherProfile"
                                   asp-action="Index">
                                    <i class="bi bi-person me-2"></i> Profile
                                </a>
                            </li>

                            <!-- SETTINGS -->
                            <li>
                                <a class="dropdown-item py-2"
                                   asp-controller="TeacherSettings"
                                   asp-action="Index">
                                    <i class="bi bi-gear me-2"></i> Settings
                                </a>
                            </li>

                            <!-- ARCHIVE -->
                            <li>
                                <a class="dropdown-item py-2"
                                   asp-controller="TeacherArchive"
                                   asp-action="Index">
                                    <i class="bi bi-archive me-2"></i> Archive
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <!-- LOGOUT -->
                            <li>
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post"
                                      class="m-0">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="dropdown-item text-danger py-2">
                                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                                    </button>
                                </form>
                            </li>

                        </ul>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>