@using Acadimy.Data
@using Acadimy.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager

@{
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    var unreadCount = 0;
    var unreadMessages = 0;

    if (!string.IsNullOrEmpty(userId))
    {
        unreadCount = await DbContext.Notifications
            .CountAsync(n => n.UserId == userId && !n.IsRead);

        unreadMessages = await DbContext.Messages
            .Where(m =>
                m.SenderId != userId &&
                !m.IsRead &&
                (m.Thread.User1Id == userId || m.Thread.User2Id == userId))
            .CountAsync();
    }
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Acadimy Teacher</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/teacher.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/teacher-home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/community.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/marketplace.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/liveclasses.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/messages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ai-assistant.css" asp-append-version="true" />
</head>

<body>

    @if (ViewBag.HideNavbar == null || ViewBag.HideNavbar == false)
    {
        @await Html.PartialAsync("_Navbarteacher", unreadCount)
    }

    <main class="main-content">
        @RenderBody()
    </main>

    <partial name="_Footer" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.addEventListener("scroll", function () {
        const nav = document.querySelector(".acadimy-navbar");
        if (!nav) return;

        if (window.scrollY > 40) {
        nav.classList.add("navbar-scrolled");
        } else {
        nav.classList.remove("navbar-scrolled");
        }
        });
    </script>

    <partial name="_AiAssistant" />

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>