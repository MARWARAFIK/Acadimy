@using Acadimy.Data
@using Acadimy.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    var unreadCount = 0;
    var unreadMessages = 0;

    if (!string.IsNullOrEmpty(userId))
    {
        unreadCount = await DbContext.Notifications
            .CountAsync(n => n.UserId == userId && !n.IsRead);

        unreadMessages = await DbContext.Messages
            .Where(m =>
                m.SenderId != userId &&
                !m.IsRead &&
                (m.Thread.User1Id == userId || m.Thread.User2Id == userId))
            .CountAsync();
    }
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acadimy - Teacher</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/teacher.css" asp-append-version="true" />
</head>

<body>
    @if (ViewBag.HideNavbar == null || ViewBag.HideNavbar == false)
    {
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Teacher" asp-action="Index">
                    <span style="color:#16a34a;">
                        <i class="bi bi-person-workspace"></i> Acadimy
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTeacher">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarTeacher">
                    <ul class="navbar-nav ms-auto align-items-center">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Teacher" asp-action="Index">
                                <i class="bi bi-house"></i> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TeacherCourses" asp-action="Index">
                                <i class="bi bi-journals"></i> My Courses
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TeacherStudents" asp-action="Index">
                                <i class="bi bi-people"></i> Students
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TeacherAssignments" asp-action="Index">
                                <i class="bi bi-file-earmark-check"></i> Assignments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Marketplace" asp-action="Index">
                                <i class="bi bi-shop"></i> Marketplace
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Community" asp-action="Index">
                                <i class="bi bi-globe"></i> Community
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Messages" asp-action="Index">
                                <i class="bi bi-chat-dots fs-5"></i> Messages

                                @if (unreadMessages > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        @unreadMessages
                                    </span>
                                }
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="LiveClasses" asp-action="Index">
                                <i class="bi bi-camera-video"></i> Live Classes
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link notif-link position-relative" asp-controller="Notifications" asp-action="Index">
                                <i class="bi bi-bell fs-5"></i>

                                @if (unreadCount > 0)
                                {
                                    <span class="notif-badge">@unreadCount</span>
                                }
                            </a>
                        </li>

                        <li class="nav-item dropdown ms-lg-3">
                            <a class="nav-link dropdown-toggle user-icon-btn" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <li class="px-3 py-2 small text-muted border-bottom">
                                    Enseignant : @User.Identity?.Name
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="TeacherProfile" asp-action="Index">
                                        <i class="bi bi-person me-2"></i> Profile
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="TeacherSettings" asp-action="Index">
                                        <i class="bi bi-gear me-2"></i> Settings
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="TeacherArchive" asp-action="Index">
                                        <i class="bi bi-archive me-2"></i> Archive
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- AI BUTTON -->
    <div id="ai-btn">
        <i class="bi bi-robot"></i>
    </div>

    <!-- AI CHAT -->
    <div id="ai-box" class="d-none">
        <div class="ai-header">
            <span>🤖 AI Assistant</span>
            <span onclick="toggleAI()" style="cursor:pointer;">✖</span>
        </div>

        <div id="ai-messages" class="ai-messages">
            <div class="ai-msg ai-bot">
                Bonjour 👋 Je peux vous aider à corriger un texte, résumer un contenu ou analyser un fichier.
            </div>
        </div>

        <div class="ai-input" style="flex-direction:column;">
            <div style="display:flex;width:100%;">
                <input type="text" id="ai-text" placeholder="Écrivez votre question..." />
                <button type="button" onclick="sendAI()">
                    <i class="bi bi-send"></i>
                </button>
            </div>

            <input type="file" id="ai-file" class="form-control mt-2" />
            <button type="button" onclick="uploadAIFile()" class="btn btn-sm btn-success mt-1">
                📄 Upload & Analyze
            </button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const btn = document.getElementById("ai-btn");
        const box = document.getElementById("ai-box");

        if (btn && box) {
        btn.addEventListener("click", function () {
        box.classList.toggle("d-none");
        });
        }

        const input = document.getElementById("ai-text");
        if (input) {
        input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
        sendAI();
        }
        });
        }
        });

        function toggleAI() {
        const box = document.getElementById("ai-box");
        if (box) box.classList.toggle("d-none");
        }

        async function sendAI() {
        const input = document.getElementById("ai-text");
        const chat = document.getElementById("ai-messages");

        if (!input || !chat) return;

        const msg = input.value.trim();
        if (!msg) return;

        chat.innerHTML += `<div class="ai-msg ai-user"><b>You:</b> ${msg}</div>`;
        input.value = "";

        try {
        const response = await fetch("/AiAssistant/Ask", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: msg })
        });

        const data = await response.json();
        chat.innerHTML += `<div class="ai-msg ai-bot"><b>AI:</b><br/>${data.answer}</div>`;
        chat.scrollTop = chat.scrollHeight;
        } catch {
        chat.innerHTML += `<div class="ai-msg ai-bot text-danger">Erreur AI Assistant.</div>`;
        }
        }

        async function uploadAIFile() {
        const fileInput = document.getElementById("ai-file");
        const chat = document.getElementById("ai-messages");

        if (!fileInput || !chat || fileInput.files.length === 0) {
        alert("Choisir un fichier");
        return;
        }

        const formData = new FormData();
        formData.append("file", fileInput.files[0]);

        chat.innerHTML += `<div class="ai-msg ai-user">📄 Fichier envoyé...</div>`;

        try {
        const response = await fetch("/AiAssistant/Upload", {
        method: "POST",
        body: formData
        });

        const data = await response.json();
        chat.innerHTML += `<div class="ai-msg ai-bot"><b>AI:</b><br/>${data.answer}</div>`;
        chat.scrollTop = chat.scrollHeight;
        fileInput.value = "";
        } catch {
        chat.innerHTML += `<div class="ai-msg ai-bot text-danger">Erreur upload fichier.</div>`;
        }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>