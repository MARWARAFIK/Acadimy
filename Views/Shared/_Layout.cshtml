<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/student.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>

    <header class="hero">

        <!-- NAVBAR -->
        <nav class="navbar job-navbar">
            <div class="container d-flex justify-content-between align-items-center">

                <a class="job-logo" href="/Home/IndexStudent">Acadimy</a>

                <ul class="job-menu">
                    <li><a class="nav-link" href="/Home/IndexStudent">Home</a></li>
                    <li><a class="nav-link" href="#">Courses</a></li>
                    <li><a class="nav-link" href="#">Applications</a></li>
                </ul>

                <!-- USER -->
                <div class="dropdown">
                    <div class="user-circle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-fill"></i>
                    </div>

                    <ul class="dropdown-menu dropdown-menu-end job-dropdown">
                        <li><a class="dropdown-item" href="/Profile/Index">Profile</a></li>
                        <li><a class="dropdown-item" href="/Profile/Settings">Settings</a></li>
                        <li><hr></li>
                        <li><a class="dropdown-item text-danger" href="/Account/Logout">Logout</a></li>
                    </ul>
                </div>

            </div>
        </nav>

        <!-- BACKGROUND -->
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>

        <div class="hero-content">
            <h1>Learn & Grow</h1>
            <p>Build your future with Acadimy</p>

            <div class="job-search">
                <input type="text" placeholder="Search courses..." />
                <select>
                    <option>Category</option>
                    <option>Dev</option>
                    <option>Design</option>
                </select>
                <button>Search</button>
            </div>
        </div>

    </header>

    <div class="container mt-5">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.addEventListener("scroll", function () {
        let navbar = document.querySelector(".job-navbar");
        navbar.classList.toggle("scrolled", window.scrollY > 50);
        });
    </script>

</body>
</html>