@model int

<nav class="navbar navbar-expand-lg acadimy-navbar">
    <div class="container-fluid px-5">

        <!-- LOGO -->
        <a class="navbar-brand d-flex align-items-center gap-2"
           asp-controller="Student"
           asp-action="Index">
            <i class="bi bi-mortarboard logo-icon"></i>
            <span>Acadimy</span>
        </a>

        <!-- TOGGLER -->
        <button class="navbar-toggler border-0"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#studentNavbar">
            <i class="bi bi-list fs-1"></i>
        </button>

        <!-- MENU -->
        <div class="collapse navbar-collapse justify-content-center" id="studentNavbar">
            <ul class="navbar-nav align-items-center gap-4">

                <!-- HOME -->
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Student" asp-action="Index">
                        Home
                    </a>
                </li>

                <!-- LEARNING -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        Learning
                    </a>

                    <ul class="dropdown-menu rounded-4 border-0 shadow-sm">

                        <li>
                            <a class="dropdown-item"
                               asp-controller="StudentCourses"
                               asp-action="Index">
                                <i class="bi bi-journal-bookmark me-2"></i> Courses
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="StudentCourses"
                               asp-action="MyCourses">
                                <i class="bi bi-bookmark-check me-2"></i> My Courses
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="StudentAssignments"
                               asp-action="Index">
                                <i class="bi bi-clipboard-check me-2"></i> Assignments
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="LiveClasses"
                               asp-action="Index">
                                <i class="bi bi-camera-video me-2"></i> Live Classes
                            </a>
                        </li>

                    </ul>
                </li>

                <!-- MARKETPLACE -->
                <li class="nav-item">
                    <a class="nav-link"
                       asp-controller="Marketplace"
                       asp-action="Index">
                        Marketplace
                    </a>
                </li>

                <!-- COMMUNITY -->
                <li class="nav-item">
                    <a class="nav-link"
                       asp-controller="Community"
                       asp-action="Index">
                        Community
                    </a>
                </li>

                <!-- MESSAGES -->
                <li class="nav-item">
                    <a class="nav-link"
                       asp-controller="Messages"
                       asp-action="Index">
                        Messages
                    </a>
                </li>

            </ul>
        </div>

        <!-- RIGHT SIDE -->
        <div class="student-nav-actions d-flex align-items-center gap-3">

            <!-- NOTIFICATIONS -->
            <a asp-controller="Notifications"
               asp-action="Index"
               class="student-circle-btn position-relative">

                <i class="bi bi-bell"></i>

                @if (Model > 0)
                {
                    <span class="student-nav-badge">@Model</span>
                }
            </a>

            <!-- PROFILE DROPDOWN -->
            <div class="dropdown">
                <a href="#" class="student-circle-btn" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle"></i>
                </a>

                <ul class="dropdown-menu dropdown-menu-end rounded-4 border-0 shadow-sm">

                    <li>
                        <a class="dropdown-item"
                           asp-controller="Profile"
                           asp-action="Index">
                            <i class="bi bi-person me-2"></i> Profile
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           asp-controller="Settings"
                           asp-action="Index">
                            <i class="bi bi-gear me-2"></i> Settings
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           asp-controller="StudentArchive"
                           asp-action="Index">
                            <i class="bi bi-archive me-2"></i> Archive
                        </a>
                    </li>

                    <li><hr class="dropdown-divider" /></li>

                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                            </button>
                        </form>
                    </li>

                </ul>
            </div>

        </div>

    </div>
</nav>