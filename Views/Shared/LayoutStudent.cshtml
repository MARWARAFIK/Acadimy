@using Acadimy.Data
@using Acadimy.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var currentUser = await UserManager.GetUserAsync(User);

    var showNotifications =
        currentUser != null &&
        (
            currentUser.NotifyNewCourse ||
            currentUser.NotifyApplicationStatus ||
            currentUser.NotifyAnnouncement ||
            currentUser.NotifyMessages
        );

    var unreadCount = 0;
    var unreadMessages = 0;

    if (currentUser != null && showNotifications)
    {
        unreadCount = await DbContext.Notifications
            .Where(n => n.UserId == currentUser.Id && !n.IsRead)
            .CountAsync();
    }

    if (currentUser != null)
    {
        unreadMessages = await DbContext.Messages
            .Where(m =>
                m.SenderId != currentUser.Id &&
                !m.IsRead &&
                (m.Thread.User1Id == currentUser.Id || m.Thread.User2Id == currentUser.Id))
            .CountAsync();
    }
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acadimy - Student</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />
</head>

<body>
    @if (ViewBag.HideNavbar == null || ViewBag.HideNavbar == false)
    {
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Student" asp-action="Index">
                    <span style="color:#16a34a;">
                        <i class="bi bi-mortarboard-fill"></i> Acadimy
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarStudent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarStudent">
                    <ul class="navbar-nav ms-auto align-items-center">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StudentCourses" asp-action="Index">Courses</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StudentCourses" asp-action="MyCourses">Mes cours</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StudentAssignments" asp-action="Index">Assignments</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Marketplace" asp-action="Index">
                                <i class="bi bi-shop"></i> Marketplace
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Community" asp-action="Index">Community</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Messages" asp-action="Index">
                                <i class="bi bi-chat-dots"></i> Messages

                                @if (unreadMessages > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        @unreadMessages
                                    </span>
                                }
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="LiveClasses" asp-action="Index">
                                <i class="bi bi-camera-video"></i> Live Classes
                            </a>
                        </li>

                        @if (showNotifications)
                        {
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Notifications" asp-action="Index">
                                    <i class="bi bi-bell"></i>

                                    @if (unreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @unreadCount
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown ms-lg-3">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">Profile</a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="Settings" asp-action="Index">Settings</a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="StudentArchive" asp-action="Index">Archive</a>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    }

    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- AI BUTTON -->
    <div id="ai-btn">
        <i class="bi bi-robot"></i>
    </div>

    <!-- AI CHAT -->
    <div id="ai-box" class="d-none">
        <div class="ai-header">
            <span>🤖 AI Assistant</span>
            <span onclick="toggleAI()" style="cursor:pointer;">✖</span>
        </div>

        <div id="ai-messages" class="ai-messages">
            <div class="ai-msg ai-bot">
                Bonjour 👋 Je peux t’aider avec les cours, projets, résumés et corrections.
            </div>
        </div>

        <div class="ai-input" style="flex-direction:column;">
            <div style="display:flex;width:100%;">
                <input type="text" id="ai-text" placeholder="Écris ta question..." />
                <button type="button" onclick="sendAI()">
                    <i class="bi bi-send"></i>
                </button>
            </div>

            <input type="file" id="ai-file" class="form-control mt-2" />
            <button type="button" onclick="uploadAIFile()" class="btn btn-sm btn-success mt-1">
                📄 Upload & Analyze
            </button>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const btn = document.getElementById("ai-btn");
        const box = document.getElementById("ai-box");

        if (btn && box) {
        btn.addEventListener("click", function () {
        box.classList.toggle("d-none");
        });
        }

        const input = document.getElementById("ai-text");
        if (input) {
        input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
        sendAI();
        }
        });
        }
        });

        function toggleAI() {
        const box = document.getElementById("ai-box");
        if (box) box.classList.toggle("d-none");
        }

        async function sendAI() {
        const input = document.getElementById("ai-text");
        const chat = document.getElementById("ai-messages");

        if (!input || !chat) return;

        const msg = input.value.trim();
        if (!msg) return;

        chat.innerHTML += `<div class="ai-msg ai-user"><b>You:</b> ${msg}</div>`;
        input.value = "";

        try {
        const response = await fetch("/AiAssistant/Ask", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: msg })
        });

        const data = await response.json();
        chat.innerHTML += `<div class="ai-msg ai-bot"><b>AI:</b><br/>${data.answer}</div>`;
        chat.scrollTop = chat.scrollHeight;
        } catch {
        chat.innerHTML += `<div class="ai-msg ai-bot text-danger">Erreur AI Assistant.</div>`;
        }
        }

        async function uploadAIFile() {
        const fileInput = document.getElementById("ai-file");
        const chat = document.getElementById("ai-messages");

        if (!fileInput || !chat || fileInput.files.length === 0) {
        alert("Choisir un fichier");
        return;
        }

        const formData = new FormData();
        formData.append("file", fileInput.files[0]);

        chat.innerHTML += `<div class="ai-msg ai-user">📄 Fichier envoyé...</div>`;

        try {
        const response = await fetch("/AiAssistant/Upload", {
        method: "POST",
        body: formData
        });

        const data = await response.json();
        chat.innerHTML += `<div class="ai-msg ai-bot"><b>AI:</b><br/>${data.answer}</div>`;
        chat.scrollTop = chat.scrollHeight;
        fileInput.value = "";
        } catch {
        chat.innerHTML += `<div class="ai-msg ai-bot text-danger">Erreur upload fichier.</div>`;
        }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>