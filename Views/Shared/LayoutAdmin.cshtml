@using Microsoft.AspNetCore.Identity
@using Acadimy.Models
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>Acadimy - Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body>

    <div class="admin-sidebar">
        <div class="admin-logo">
            <i class="bi bi-shield-lock"></i> Acadimy Admin
        </div>

        <a asp-controller="Admin" asp-action="Index">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>

        <a asp-controller="Admin" asp-action="Students">
            <i class="bi bi-mortarboard me-2"></i> Students
        </a>

        <a asp-controller="Admin" asp-action="Teachers">
            <i class="bi bi-person-workspace me-2"></i> Teachers
        </a>

        <a asp-controller="Admin" asp-action="Projects">
            <i class="bi bi-folder-check me-2"></i> Projects
        </a>

        <a asp-controller="Admin" asp-action="Courses">
            <i class="bi bi-journals me-2"></i> Courses
        </a>
        <a asp-controller="Admin" asp-action="Settings">
            <i class="bi bi-gear me-2"></i> Settings
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <button class="btn btn-danger w-100 rounded-pill">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </form>
    </div>

    <div class="admin-main">
        <div class="admin-topbar d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold mb-0">Admin Panel</h4>
                <small class="text-muted">@currentUser?.Email</small>
            </div>

            <span class="badge bg-success rounded-pill px-3 py-2">
                Admin
            </span>
        </div>

        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>